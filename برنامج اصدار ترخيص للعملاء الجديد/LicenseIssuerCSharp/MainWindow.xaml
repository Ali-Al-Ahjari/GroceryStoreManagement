<Window x:Class="LicenseIssuerCSharp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="نظام إصدار التراخيص" Height="580" Width="820"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" Icon="Properties/app_icon.ico">
    <Border CornerRadius="14" Background="#FF0F172A" BorderBrush="#3B82F6" BorderThickness="1.2">
        <Grid FlowDirection="RightToLeft">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Grid Grid.Row="0" Background="#10FFFFFF" MouseDown="TitleBar_MouseDown" Height="40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Glow Icon & Title -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0,0,0">
                    <Ellipse Width="8" Height="8" Fill="#FF3B82F6" Margin="0,0,8,0">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#FF3B82F6" BlurRadius="8" ShadowDepth="0"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock Text="مُصدر تراخيص النظام المتكامل لإدارة المتجر" Foreground="#FFFFFFFF" FontSize="13" FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Window Control Buttons (Close & Minimize) on Left (Standard RTL) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Button Click="MinimizeButton_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Width="26" Height="26">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="Transparent" CornerRadius="13">
                                    <Path Data="M0,4 L10,4" Stroke="#FF94A3B8" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="#1AFFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Click="CloseButton_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Width="26" Height="26" Margin="6,0,0,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="Transparent" CornerRadius="13">
                                    <Path Data="M0,0 L8,8 M8,0 L0,8" Stroke="#FF94A3B8" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="#FFE11D48"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Main Layout Content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar (Left) -->
                <Grid Grid.Column="0" Background="#08FFFFFF">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Profile/Icon area -->
                    <StackPanel Grid.Row="0" Margin="15,25,15,25" HorizontalAlignment="Center">
                        <Border Width="60" Height="60" CornerRadius="30" Background="#103B82F6" BorderBrush="#3B82F6" BorderThickness="1" HorizontalAlignment="Center">
                            <Border.Effect>
                                <DropShadowEffect Color="#FF3B82F6" BlurRadius="12" ShadowDepth="0" Opacity="0.5"/>
                            </Border.Effect>
                            <!-- Glowing Shield Icon -->
                            <Path Data="M10,0 L2,4 L2,12 C2,17 5.5,21.5 10,24 C14.5,21.5 18,17 18,12 L18,4 L10,0 Z M10,12 L10,6 C10.5,6 11,6.5 11,7 L11,12 C11,12.5 10.5,13 10,13 Z" 
                                  Fill="#FF60A5FA" Stretch="Uniform" Margin="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="لوحة التحكم بالترخيص" Foreground="#FF94A3B8" FontSize="11" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Navigation Items -->
                    <StackPanel Grid.Row="1" Margin="10,0,10,0">
                        <Button x:Name="BtnDashboard" Click="NavButton_Click" Content="لوحة الإحصائيات" Style="{StaticResource NavButton}" Tag="Active"/>
                        <Button x:Name="BtnIssue" Click="NavButton_Click" Content="إصدار ترخيص جديد" Style="{StaticResource NavButton}"/>
                        <Button x:Name="BtnHistory" Click="NavButton_Click" Content="سجل التراخيص" Style="{StaticResource NavButton}"/>
                        <Button x:Name="BtnSettings" Click="NavButton_Click" Content="الإعدادات والأمان" Style="{StaticResource NavButton}"/>
                    </StackPanel>

                    <!-- Sidebar Footer -->
                    <TextBlock Grid.Row="2" Text="C# Issuer v2.0.0" Foreground="#FF475569" FontSize="10" Margin="15,0,15,15" HorizontalAlignment="Center"/>
                </Grid>

                <!-- Workspaces/Tabs Content Area (Right) -->
                <Grid Grid.Column="1" Margin="20,15,20,20">
                    
                    <!-- TAB 1: DASHBOARD -->
                    <Grid x:Name="GridDashboard" Visibility="Visible">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0" Margin="0,0,0,25">
                            <TextBlock Text="لوحة الإحصائيات" Foreground="#FFFFFFFF" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text="نظرة عامة على تراخيص نظام إدارة المتجر الصادرة للعملاء" Foreground="#FF94A3B8" FontSize="12" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Cards Panel -->
                        <Grid Grid.Row="1" VerticalAlignment="Top">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Card 1: Total -->
                            <Border Grid.Column="0" CornerRadius="10" Background="#201E293B" BorderBrush="#20FFFFFF" BorderThickness="1" Padding="15">
                                <StackPanel>
                                    <TextBlock Text="إجمالي التراخيص" Foreground="#FF94A3B8" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="TxtTotalLicenses" Text="0" Foreground="#FFFFFFFF" FontSize="36" FontWeight="Bold" Margin="0,10,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Card 2: Active -->
                            <Border Grid.Column="2" CornerRadius="10" Background="#201E293B" BorderBrush="#3022C55E" BorderThickness="1" Padding="15">
                                <StackPanel>
                                    <TextBlock Text="التراخيص النشطة" Foreground="#FF86EFAC" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="TxtActiveLicenses" Text="0" Foreground="#FF22C55E" FontSize="36" FontWeight="Bold" Margin="0,10,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Card 3: Expired -->
                            <Border Grid.Column="4" CornerRadius="10" Background="#201E293B" BorderBrush="#30EF4444" BorderThickness="1" Padding="15">
                                <StackPanel>
                                    <TextBlock Text="التراخيص المنتهية" Foreground="#FFFCA5A5" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="TxtExpiredLicenses" Text="0" Foreground="#FFEF4444" FontSize="36" FontWeight="Bold" Margin="0,10,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- TAB 2: ISSUE LICENSE -->
                    <Grid x:Name="GridIssue" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel Grid.Row="0" Margin="0,0,0,15">
                            <TextBlock Text="إصدار ترخيص جديد للعميل" Foreground="#FFFFFFFF" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text="أدخل بصمة جهاز العميل وتفاصيل التفعيل للحصول على الكود فوراً" Foreground="#FF94A3B8" FontSize="12" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Issue Form Grid -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="320"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left Side: Inputs -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="اسم العميل (ملاحظة)" Foreground="#FFCBD5E1" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="TxtCustomerName" Style="{StaticResource GlassTextBox}" Margin="0,0,0,15"/>

                                <TextBlock Text="بصمة جهاز العميل" Foreground="#FFCBD5E1" FontSize="12" Margin="0,0,0,5"/>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtFingerprint" Style="{StaticResource GlassTextBox}" Grid.Column="0"/>
                                    <Button Click="PasteFingerprint_Click" Content="لصق" Style="{StaticResource PrimaryButton}" Grid.Column="1" Margin="8,0,0,0" Padding="15,6"/>
                                </Grid>

                                <TextBlock Text="مدة الصلاحية (أيام)" Foreground="#FFCBD5E1" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="TxtExpiryDays" Text="30" Style="{StaticResource GlassTextBox}" Margin="0,0,0,20"/>

                                <Button Click="GenerateLicense_Click" Content="إصدار وتوليد كود التفعيل" Style="{StaticResource PrimaryButton}" Height="40" Margin="0,5,0,0"/>
                            </StackPanel>

                            <!-- Right Side: Token Output -->
                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,5">
                                    <TextBlock Text="كود التفعيل الناتج" Foreground="#FFCBD5E1" FontSize="12" VerticalAlignment="Center"/>
                                    <Button Click="CopyToken_Click" Content="نسخ الكود" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" Padding="10,4" FontSize="11"/>
                                </Grid>
                                
                                <TextBox x:Name="TxtOutputToken" Grid.Row="1" Style="{StaticResource GlassTextBox}" TextWrapping="Wrap" IsReadOnly="True" AcceptsReturn="True" Foreground="#FF60A5FA" FontSize="12" FontFamily="Consolas"/>
                            </Grid>
                        </Grid>
                    </Grid>

                    <!-- TAB 3: HISTORY -->
                    <Grid x:Name="GridHistory" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="سجل التراخيص الصادرة" Foreground="#FFFFFFFF" FontSize="20" FontWeight="Bold"/>
                                <TextBlock Text="تاريخ إصدار وتفاصيل تراخيص العملاء المسجلة في النظام" Foreground="#FF94A3B8" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Click="RefreshHistory_Click" Content="تحديث السجل" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" VerticalAlignment="Center" Padding="12,6" FontSize="12"/>
                        </Grid>

                        <!-- Scrollable History List -->
                        <ScrollViewer Grid.Row="1" Style="{StaticResource ModernScrollViewer}">
                            <ItemsControl x:Name="ListHistoryItems">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="8" Background="#201E293B" BorderBrush="#15FFFFFF" BorderThickness="1" Margin="0,0,0,10" Padding="12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <StackPanel Grid.Column="0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="العميل: " Foreground="#FF94A3B8" FontSize="13"/>
                                                        <TextBlock Text="{Binding CustomerName}" Foreground="#FFFFFFFF" FontSize="13" FontWeight="Bold"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                        <TextBlock Text="بصمة الجهاز: " Foreground="#FF475569" FontSize="11"/>
                                                        <TextBlock Text="{Binding MachineFingerprint}" Foreground="#FF94A3B8" FontSize="11" FontFamily="Consolas"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                        <TextBlock Text="تاريخ الانتهاء: " Foreground="#FF475569" FontSize="11"/>
                                                        <TextBlock Text="{Binding ExpiryDate}" Foreground="#FF60A5FA" FontSize="11"/>
                                                        <TextBlock Text=" | تاريخ الإصدار: " Foreground="#FF475569" FontSize="11" Margin="10,0,0,0"/>
                                                        <TextBlock Text="{Binding IssueDate}" Foreground="#FF94A3B8" FontSize="11"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <Button Grid.Column="1" Click="CopyHistoryToken_Click" Content="نسخ كود الترخيص" Style="{StaticResource PrimaryButton}" VerticalAlignment="Center" Padding="10,6" FontSize="11" Tag="{Binding Token}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>

                    <!-- TAB 4: SETTINGS -->
                    <Grid x:Name="GridSettings" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,15">
                            <TextBlock Text="الإعدادات والأمان" Foreground="#FFFFFFFF" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text="تكوين خيارات المصدر والمفتاح الخاص وتوليد أزواج مفاتيح تشفير جديدة" Foreground="#FF94A3B8" FontSize="12" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Settings Panel -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left Side: App Config -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="اسم المصدر الافتراضي (Issuer)" Foreground="#FFCBD5E1" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="TxtSettingsIssuer" Style="{StaticResource GlassTextBox}" Margin="0,0,0,15"/>

                                <TextBlock Text="المفتاح الخاص المخصص (PEM format)" Foreground="#FFCBD5E1" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="TxtSettingsKey" Style="{StaticResource GlassTextBox}" TextWrapping="Wrap" AcceptsReturn="True" Height="140" Margin="0,0,0,5" FontSize="10" FontFamily="Consolas"/>
                                <TextBlock Text="ملاحظة: اتركه فارغاً لاستخدام المفتاح المدمج المتوافق مع التطبيق تلقائياً." Foreground="#FF64748B" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,15"/>

                                <Button Click="SaveSettings_Click" Content="حفظ التغييرات" Style="{StaticResource PrimaryButton}" Height="35"/>
                            </StackPanel>

                            <!-- Right Side: Keypair Generator -->
                            <Border Grid.Column="2" CornerRadius="10" Background="#201E293B" BorderBrush="#15FFFFFF" BorderThickness="1" Padding="15" VerticalAlignment="Top">
                                <StackPanel>
                                    <TextBlock Text="مولد مفاتيح التشفير RSA 3072" Foreground="#FFFFFFFF" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <TextBlock Text="يقوم بتوليد زوج مفاتيح جديد (خاص وعام) وتصديرهما كملفات بصيغة PEM لاستخدامهما في التطبيقات." Foreground="#FF94A3B8" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,15"/>

                                    <Button Click="GenerateKeys_Click" Content="توليد وتصدير المفاتيح" Style="{StaticResource PrimaryButton}" Height="35" Background="#FF2563EB"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                    
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
