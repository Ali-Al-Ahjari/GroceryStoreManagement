<Window x:Class="GroceryStoreManagement.Windows.SuspendedSalesWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="الفواتير المعلقة" Height="560" Width="860" WindowStartupLocation="CenterOwner" WindowStyle="None" AllowsTransparency="True" Background="Transparent" ResizeMode="NoResize" FlowDirection="RightToLeft" Language="ar-YE" ShowInTaskbar="False" MaxHeight="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Height}" MaxWidth="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Width}">

    <Border CornerRadius="16" Background="{DynamicResource SurfaceBrush}" Effect="{DynamicResource CardShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource SecondaryGradient}" CornerRadius="16,16,0,0" Padding="20,15" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="الفواتير المعلقة" FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <Button Click="CloseButton_Click" Style="{StaticResource IconButton}" Foreground="White" HorizontalAlignment="Left">
                        <TextBlock Text="&#xE711;" FontFamily="{StaticResource IconFont}" />
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="اختر فاتورة معلقة لاستدعائها واستكمال الدفع." Style="{StaticResource BodyLabel}" Margin="0,0,0,10"/>

                <DataGrid x:Name="SuspendedGrid" Grid.Row="1" Style="{StaticResource ModernDataGridStyle}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding SuspendedSaleID}" Width="80" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                        <DataGridTextColumn Header="الوقت" Binding="{Binding DisplayCreatedAt}" Width="180" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                        <DataGridTextColumn Header="العميل" Binding="{Binding CustomerName}" Width="1.5*" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                        <DataGridTextColumn Header="الأصناف" Binding="{Binding ItemLinesCount}" Width="90" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                        <DataGridTextColumn Header="الإجمالي" Binding="{Binding NetTotal}" Width="120" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                        <DataGridTextColumn Header="ملاحظات" Binding="{Binding Notes}" Width="2*" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <Border Grid.Row="2" BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,1,0,0" Padding="20,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" FlowDirection="LeftToRight">
                    <Button Click="ResumeSelected_Click" Style="{StaticResource SecondaryButton}" Padding="18,10" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE73E;" FontFamily="{StaticResource IconFont}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Text="استدعاء الفاتورة المحددة" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Click="DeleteSelected_Click" Style="{StaticResource OutlineButton}" Padding="18,10" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74D;" FontFamily="{StaticResource IconFont}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Text="حذف الفاتورة المحددة" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Click="CloseButton_Click" Style="{StaticResource OutlineButton}" Padding="18,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE711;" FontFamily="{StaticResource IconFont}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Text="إغلاق" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
