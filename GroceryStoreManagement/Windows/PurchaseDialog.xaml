<Window x:Class="GroceryStoreManagement.Windows.PurchaseDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="فاتورة شراء جديدة" Height="770" Width="950" WindowStartupLocation="CenterOwner" WindowStyle="None" AllowsTransparency="True" Background="Transparent" ResizeMode="NoResize" FlowDirection="RightToLeft" Language="ar-YE" ShowInTaskbar="False" MaxHeight="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Height}" MaxWidth="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Width}">

    <Border CornerRadius="16" Background="{DynamicResource SurfaceBrush}" Effect="{DynamicResource CardShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource PrimaryGradient}" CornerRadius="16,16,0,0" Padding="20,15">
                <Grid FlowDirection="LeftToRight">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Click="CancelButton_Click" Style="{StaticResource IconButton}" Foreground="White" Width="36" Height="36" FontSize="16" FontWeight="Bold" Margin="0,0,12,0">
                        <TextBlock Text="&#xE711;" FontFamily="{StaticResource IconFont}" />
                    </Button>
                    <TextBlock Grid.Column="1" x:Name="HeaderText" Text="فاتورة شراء جديدة" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Invoice Details -->
                    <RowDefinition Height="Auto"/>
                    <!-- Add Item -->
                    <RowDefinition Height="*"/>
                    <!-- Grid -->
                    <RowDefinition Height="Auto"/>
                    <!-- Totals -->
                </Grid.RowDefinitions>

                <!-- 1. Invoice Details -->
                <Border Grid.Row="0" Background="{DynamicResource BackgroundBrush}" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Supplier -->
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="المورد *" Style="{StaticResource LabelStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="SupplierComboBox" Grid.Column="0" Style="{StaticResource ModernComboBox}" DisplayMemberPath="Name" Margin="0,0,8,0"/>
                                <Button Grid.Column="1" Click="AddSupplier_Click" Style="{StaticResource IconButton}" Width="36" Height="36" ToolTip="إضافة مورد">
                                    <TextBlock Text="&#xE710;" FontFamily="{StaticResource IconFont}" FontSize="16"/>
                                </Button>
                            </Grid>
                        </StackPanel>

                        <!-- Invoice Number -->
                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="رقم فاتورة المورد" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="SupplierInvoiceTextBox" Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>

                        <!-- Notes -->
                        <StackPanel Grid.Column="2" Margin="0,0,10,0">
                            <TextBlock Text="ملاحظات" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="NotesTextBox" Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>

                        <!-- Internal Number -->
                        <StackPanel Grid.Column="3" VerticalAlignment="Center">
                            <TextBlock x:Name="InvoiceNumberText" Text="فاتورة رقم: --" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 2. Add Item -->
                <Border Grid.Row="1" Background="{DynamicResource BackgroundBrush}" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="المنتج" Style="{StaticResource LabelStyle}"/>
                            <ComboBox x:Name="ProductComboBox" Style="{StaticResource ModernComboBox}" DisplayMemberPath="Name" IsEditable="True" SelectionChanged="ProductComboBox_SelectionChanged"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="الكمية" Style="{StaticResource LabelStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="-" Click="DecreaseInputQty_Click" Style="{StaticResource OutlineButton}" Width="34" Height="42" Padding="0" Margin="0,0,6,0"/>
                                <TextBox x:Name="QuantityTextBox" Grid.Column="1" Style="{StaticResource ModernTextBox}" Text="1" TextAlignment="Center" FlowDirection="LeftToRight"/>
                                <Button Grid.Column="2" Content="+" Click="IncreaseInputQty_Click" Style="{StaticResource OutlineButton}" Width="34" Height="42" Padding="0" Margin="6,0,0,0"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,10,0">
                            <TextBlock Text="سعر الشراء" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="PriceTextBox" Style="{StaticResource ModernTextBox}" TextAlignment="Center" FlowDirection="LeftToRight"/>
                        </StackPanel>

                        <Button Grid.Column="3" Click="AddProduct_Click" Style="{StaticResource PrimaryButton}" VerticalAlignment="Bottom" Height="42" MinWidth="110">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE710;" FontFamily="{StaticResource IconFont}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="إضافة" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- 3. Grid -->
                <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="0">
                    <DataGrid x:Name="PurchaseItemsGrid" Style="{StaticResource ModernDataGridStyle}" AutoGenerateColumns="False" IsReadOnly="True" FlowDirection="RightToLeft">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="المنتج" Binding="{Binding ProductName}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridTextColumnElementStyle}">
                                        <Setter Property="FlowDirection" Value="RightToLeft"/>
                                        <Setter Property="TextAlignment" Value="Right"/>
                                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="الكمية" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="-" Width="24" Height="24" Click="DecreaseItemQty_Click" Style="{StaticResource OutlineButton}" Padding="0"/>
                                            <TextBlock Text="{Binding Quantity}" VerticalAlignment="Center" Margin="10,0" FontWeight="Bold" Width="30" TextAlignment="Center"/>
                                            <Button Content="+" Width="24" Height="24" Click="IncreaseItemQty_Click" Style="{StaticResource OutlineButton}" Padding="0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="السعر" Binding="{Binding UnitPrice, StringFormat='{}{0:#,##0.##}'}" Width="120" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                            <DataGridTextColumn Header="الإجمالي" Binding="{Binding TotalPrice, StringFormat='{}{0:#,##0.##}'}" Width="120" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                            <DataGridTemplateColumn Header="حذف" Width="70">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Click="RemoveProduct_Click" Tag="{Binding ProductID}" Style="{StaticResource IconButton}" Foreground="{DynamicResource DangerBrush}" Width="30" Height="30">
                                            <TextBlock Text="&#xE74D;" FontFamily="{StaticResource IconFont}"/>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- 4. Totals -->
                <Border Grid.Row="3" Margin="0,15,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="260"/>
                        </Grid.ColumnDefinitions>

                        <!-- Item Count -->
                        <Border Grid.Column="0" Background="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,12,0">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="عدد العناصر" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="ItemCountText" Text="0" FontWeight="Bold" FontSize="20" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Payment Inputs -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,0">
                            <StackPanel Margin="8,0">
                                <TextBlock Text="الخصم" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="DiscountTextBox" Width="100" Style="{StaticResource ModernTextBox}" Text="0" TextChanged="CalculateTotals" FlowDirection="LeftToRight" TextAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Margin="8,0">
                                <TextBlock Text="المدفوع" Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="PaidAmountTextBox" Width="100" Style="{StaticResource ModernTextBox}" Text="0" TextChanged="CalculateTotals" FlowDirection="LeftToRight" TextAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Totals -->
                        <Border Grid.Column="2" Background="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="12">
                            <StackPanel>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="المجموع:" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1" x:Name="SubtotalText" Text="0.00" FontWeight="Bold" Width="130" TextAlignment="Left" FlowDirection="LeftToRight"/>
                                </Grid>

                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="الخصم:" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1" x:Name="DiscountAmountText" Text="0.00" FontWeight="Bold" Width="130" TextAlignment="Left" FlowDirection="LeftToRight" Foreground="{DynamicResource WarningBrush}"/>
                                </Grid>

                                <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,2,0,8"/>

                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="الإجمالي:" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1" x:Name="TotalAmountText" Text="0.00" FontWeight="Bold" FontSize="16" Width="130" TextAlignment="Left" FlowDirection="LeftToRight" Foreground="{DynamicResource PrimaryBrush}"/>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="المتبقي:" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1" x:Name="RemainingAmountText" Text="0.00" FontWeight="Bold" Width="130" TextAlignment="Left" FlowDirection="LeftToRight" Foreground="{DynamicResource ErrorBrush}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>


            <!-- Footer Buttons -->
            <Border Grid.Row="2" BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,1,0,0" Padding="20,15">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" FlowDirection="LeftToRight">
                    <Button Click="CancelButton_Click" Style="{StaticResource OutlineButton}" Padding="20,10" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE711;" FontFamily="{StaticResource IconFont}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Text="إلغاء" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Click="SavePurchase_Click" Style="{StaticResource PrimaryButton}" Padding="20,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74E;" FontFamily="{StaticResource IconFont}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Text="حفظ الفاتورة" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>

</Window>


