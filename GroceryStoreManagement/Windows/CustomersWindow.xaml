<UserControl x:Class="GroceryStoreManagement.Windows.CustomersWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" FlowDirection="RightToLeft" Language="ar-YE" Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header & Stats -->
            <RowDefinition Height="Auto"/>
            <!-- Filters -->
            <RowDefinition Height="*"/>
            <!-- DataGrid -->
        </Grid.RowDefinitions>

        <!-- 1. Header & Stats Cards -->
        <Grid Grid.Row="0" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Title -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="إدارة العملاء" Style="{StaticResource HeaderLabel}"/>
                <TextBlock Text="سجل بيانات العملاء والديون" Style="{StaticResource BodyLabel}" Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Stats Cards -->
            <Grid Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="5,0" Padding="15">
                    <StackPanel>
                        <TextBlock Text="إجمالي العملاء" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="TxtTotalCustomers" Text="0" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="5,0" Padding="15">
                    <StackPanel>
                        <TextBlock Text="عليهم ديون" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="TxtWithDebt" Text="0" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardBorder}" Margin="5,0" Padding="15">
                    <StackPanel>
                        <TextBlock Text="إجمالي الديون" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="TxtTotalDebtAmount" Text="0.00" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource ErrorBrush}" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- 2. Actions & Filters -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,20" Padding="15">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <Grid HorizontalAlignment="Left" MinWidth="900">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Add Button -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Search -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Checkbox -->
                    <ColumnDefinition Width="*"/>
                    <!-- Spacer -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Export -->
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnAddCustomer" Grid.Column="0" Click="BtnAddCustomer_Click" Style="{StaticResource PrimaryButton}" Margin="0,0,20,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="{StaticResource IconFont}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="إضافة عميل" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Search -->
                <Grid Grid.Column="1" Margin="0,0,15,0" Width="250">
                    <TextBox x:Name="TxtSearch" Style="{StaticResource ModernTextBox}" Padding="30,10,10,10" TextChanged="TxtSearch_TextChanged"/>
                    <TextBlock Text="&#xE721;" FontFamily="{StaticResource IconFont}" FontSize="16" IsHitTestVisible="False" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" Foreground="{DynamicResource TextMutedBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=TxtSearch}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <CheckBox x:Name="ChkShowWithDebt" Grid.Column="2" Content="عرض المدينين فقط" VerticalAlignment="Center" Checked="ChkShowWithDebt_Checked" Unchecked="ChkShowWithDebt_Unchecked"/>

                <Button Grid.Column="4" Style="{StaticResource OutlineButton}" Click="BtnExport_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE896;" FontFamily="{StaticResource IconFont}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="تصدير" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                </Grid>
            </ScrollViewer>
        </Border>

        <!-- 3. DataGrid -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="0">
            <DataGrid x:Name="CustomersDataGrid" Style="{StaticResource ModernDataGridStyle}" AutoGenerateColumns="False" BorderThickness="0" MouseDoubleClick="CustomersDataGrid_MouseDoubleClick" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding CustomerID}" Width="60" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTextColumn Header="الاسم" Binding="{Binding Name}" Width="*" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTextColumn Header="الهاتف" Binding="{Binding Phone}" Width="120" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTextColumn Header="العنوان" Binding="{Binding Address}" Width="150" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTextColumn Header="عدد المشتريات" Binding="{Binding PurchaseCount}" Width="100" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTextColumn Header="إجمالي المشتريات" Binding="{Binding TotalPurchases, StringFormat='{}{0:#,##0.##}'}" Width="120" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTextColumn Header="الدين الحالي" Binding="{Binding CurrentDebt, StringFormat='{}{0:#,##0.##}'}" Width="100" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTextColumn Header="حد الدين" Binding="{Binding CreditLimit, StringFormat='{}{0:#,##0.##}'}" Width="100" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTextColumn Header="استهلاك الحد" Binding="{Binding DisplayCreditUsage}" Width="95" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>

                    <DataGridTemplateColumn Header="الإجراءات" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button ToolTip="سداد دين" Click="BtnPayDebt_Click" Tag="{Binding CustomerID}" Style="{StaticResource IconButton}" Margin="2">
                                        <TextBlock Text="&#xE8A5;" FontFamily="{StaticResource IconFont}" FontSize="14"/>
                                    </Button>
                                    <Button ToolTip="تعديل" Click="BtnEditCustomer_Click" Tag="{Binding CustomerID}" Style="{StaticResource IconButton}" Margin="2">
                                        <TextBlock Text="&#xE70F;" FontFamily="{StaticResource IconFont}" FontSize="14"/>
                                    </Button>
                                    <Button ToolTip="حذف" Click="BtnDeleteCustomer_Click" Tag="{Binding CustomerID}" Style="{StaticResource IconButton}" Foreground="{DynamicResource DangerBrush}" Margin="2">
                                        <TextBlock Text="&#xE74D;" FontFamily="{StaticResource IconFont}" FontSize="14"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

    </Grid>
</UserControl>



