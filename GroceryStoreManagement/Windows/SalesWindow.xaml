<UserControl x:Class="GroceryStoreManagement.Windows.SalesWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" FlowDirection="RightToLeft" Language="ar-YE" Background="{StaticResource BackgroundBrush}" d:DesignHeight="700" d:DesignWidth="1000">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header & Stats -->
            <RowDefinition Height="Auto"/>
            <!-- Action Bar & Filters -->
            <RowDefinition Height="*"/>
            <!-- DataGrid -->
            <RowDefinition Height="Auto"/>
            <!-- Footer / Pagination -->
        </Grid.RowDefinitions>

        <!-- 1. Header & Stats Cards -->
        <Grid Grid.Row="0" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Title -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="إدارة المبيعات" Style="{StaticResource HeaderLabel}"/>
                <TextBlock Text="سجل الفواتير والمبيعات اليومية" Style="{StaticResource BodyLabel}" Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Stats Cards -->
            <Grid Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total Invoices -->
                <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="5,0" Padding="15">
                    <StackPanel>
                        <TextBlock Text="عدد الفواتير" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="TotalInvoicesStatText" Text="0" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Total Sales -->
                <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="5,0" Padding="15">
                    <StackPanel>
                        <TextBlock Text="إجمالي المبيعات" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="TotalSalesStatText" Text="ر.ي 0" FontSize="20" FontWeight="Bold" Foreground="{StaticResource SecondaryBrush}" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Total Paid -->
                <Border Grid.Column="2" Style="{StaticResource CardBorder}" Margin="5,0" Padding="15">
                    <StackPanel>
                        <TextBlock Text="المدفوع" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="TotalPaidStatText" Text="ر.ي 0" FontSize="20" FontWeight="Bold" Foreground="Green" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Remaining -->
                <Border Grid.Column="3" Style="{StaticResource CardBorder}" Margin="5,0" Padding="15">
                    <StackPanel>
                        <TextBlock Text="بقي/آجل" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="TotalRemainingStatText" Text="ر.ي 0" FontSize="20" FontWeight="Bold" Foreground="{StaticResource ErrorBrush}" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- 2. Action Bar & Filters -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,20" Padding="15">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <Grid HorizontalAlignment="Left" MinWidth="1100">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- New Invoice Button -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Search -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Filters -->
                    <ColumnDefinition Width="*"/>
                    <!-- Spacer -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Shift Controls -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Reset -->
                </Grid.ColumnDefinitions>

                <Button x:Name="NewInvoiceButton" Grid.Column="0" Click="NewInvoice_Click" Style="{StaticResource PrimaryButton}" Margin="0,0,20,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="{StaticResource IconFont}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="فاتورة جديدة" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Search -->
                <Grid Grid.Column="1" Margin="0,0,15,0" Width="250">
                    <TextBox x:Name="SearchTextBox" Style="{StaticResource ModernTextBox}" Padding="30,10,10,10" TextChanged="SearchTextBox_TextChanged"/>
                    <TextBlock Text="&#xE721;" FontFamily="{StaticResource IconFont}" FontSize="16" IsHitTestVisible="False" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" Foreground="#AAA"/>
                    <Button x:Name="ClearSearchButton" Click="ClearSearch_Click" Visibility="Collapsed" Style="{StaticResource IconButton}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0" Width="20" Height="20">
                        <TextBlock Text="&#xE711;" FontFamily="{StaticResource IconFont}" FontSize="10" />
                    </Button>
                </Grid>

                <!-- Filters -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <DatePicker x:Name="DateFromPicker" Width="120" Margin="5,0" SelectedDateChanged="FilterChanged" VerticalAlignment="Center" FlowDirection="LeftToRight"/>
                    <TextBlock Text="إلى" VerticalAlignment="Center"/>
                    <DatePicker x:Name="DateToPicker" Width="120" Margin="5,0" SelectedDateChanged="FilterChanged" VerticalAlignment="Center" FlowDirection="LeftToRight"/>

                    <ComboBox x:Name="PaymentStatusComboBox" Width="120" Margin="10,0,0,0" Style="{StaticResource ModernComboBox}" SelectionChanged="FilterChanged">
                        <ComboBoxItem Content="الكل" IsSelected="True"/>
                        <ComboBoxItem Content="مدفوعة بالكامل"/>
                        <!-- Index 1 -->
                        <ComboBoxItem Content="مدفوعة جزئياً"/>
                        <!-- Index 2 -->
                        <ComboBoxItem Content="غير مدفوعة"/>
                        <!-- Index 3 -->
                    </ComboBox>
                </StackPanel>

                <!-- Shift Controls -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                    <TextBlock x:Name="ShiftStatusText" Text="الوردية: غير مفتوحة" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold" Foreground="{StaticResource WarningBrush}"/>
                    <Button x:Name="StartShiftButton" Click="StartShift_Click" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Padding="14,9">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7C3;" FontFamily="{StaticResource IconFont}" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Text="بدء وردية" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="CloseShiftButton" Click="CloseShift_Click" Style="{StaticResource OutlineButton}" Padding="14,9">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE749;" FontFamily="{StaticResource IconFont}" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Text="إغلاق وردية" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Reset -->
                <Button Grid.Column="5" Click="ResetFilters_Click" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" Padding="16,10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" FontFamily="{StaticResource IconFont}" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="إعادة تعيين" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                </Grid>
            </ScrollViewer>
        </Border>

        <!-- 3. DataGrid -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="0">
            <DataGrid x:Name="SalesGrid" Style="{StaticResource ModernDataGridStyle}" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="SalesGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding SaleID}" Width="70" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTextColumn Header="التاريخ" Binding="{Binding SaleDate, StringFormat=yyyy/MM/dd HH:mm}" Width="150" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTextColumn Header="العميل" Binding="{Binding CustomerName}" Width="*" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTextColumn Header="عدد العناصر" Binding="{Binding ItemCount}" Width="90" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTextColumn Header="الإجمالي" Binding="{Binding DisplayTotal}" Width="120" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTextColumn Header="المدفوع" Binding="{Binding DisplayPaidAmount}" Width="120" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTextColumn Header="المتبقي" Binding="{Binding DisplayRemainingAmount}" Width="120" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>

                    <DataGridTemplateColumn Header="الحالة" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding PaymentStatusColor}" CornerRadius="5" Padding="5,2" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding PaymentStatusArabic}" Foreground="White" FontSize="11"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="الإجراءات" Width="230">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button ToolTip="عرض التفاصيل" Click="ViewSale_Click" Tag="{Binding SaleID}" Style="{StaticResource IconButton}" Margin="2">
                                        <TextBlock Text="&#xE890;" FontFamily="{StaticResource IconFont}" FontSize="14"/>
                                    </Button>
                                    <Button ToolTip="تعديل" Click="EditSale_Click" Tag="{Binding SaleID}" Style="{StaticResource IconButton}" Margin="2">
                                        <TextBlock Text="&#xE70F;" FontFamily="{StaticResource IconFont}" FontSize="14"/>
                                    </Button>
                                    <Button ToolTip="سداد" Click="PaySale_Click" Tag="{Binding SaleID}" Style="{StaticResource IconButton}" Margin="2">
                                        <TextBlock Text="&#xE8A5;" FontFamily="{StaticResource IconFont}" FontSize="14"/>
                                    </Button>
                                    <Button ToolTip="مرتجع" Click="CreateReturn_Click" Tag="{Binding SaleID}" Style="{StaticResource IconButton}" Margin="2">
                                        <TextBlock Text="&#xE7A7;" FontFamily="{StaticResource IconFont}" FontSize="14"/>
                                    </Button>
                                    <Button ToolTip="طباعة" Click="PrintSale_Click" Tag="{Binding SaleID}" Style="{StaticResource IconButton}" Margin="2">
                                        <TextBlock Text="&#xE749;" FontFamily="{StaticResource IconFont}" FontSize="14"/>
                                    </Button>
                                    <Button ToolTip="حذف" Click="DeleteSale_Click" Tag="{Binding SaleID}" Style="{StaticResource IconButton}" Foreground="Red" Margin="2">
                                        <TextBlock Text="&#xE74D;" FontFamily="{StaticResource IconFont}" FontSize="14"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- 4. Pagination / Footer -->
        <Grid Grid.Row="3" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Page Size -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Text="عرض:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox x:Name="PageSizeComboBox" SelectionChanged="PageSizeChanged" Width="60" SelectedIndex="0" Height="30" Margin="0,5,0,0">
                    <ComboBoxItem Content="10"/>
                    <ComboBoxItem Content="20"/>
                    <ComboBoxItem Content="50"/>
                    <ComboBoxItem Content="100"/>
                </ComboBox>
            </StackPanel>

            <!-- Total Summary (Footer) -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="الإجمالي الكلي:" FontWeight="Bold" Margin="0,17,5,0"/>
                <TextBlock x:Name="TotalSalesText" Text="ر.ي 0" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,17,0,0"/>
            </StackPanel>

            <!-- Pagination Buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <TextBlock x:Name="PageInfoText" Text="عرض 0-0 من 0" VerticalAlignment="Center" Margin="10,0"/>
                <Button x:Name="PrevPageButton" Click="PrevPage_Click" Style="{StaticResource OutlineButton}" Margin="5,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72A;" FontFamily="{StaticResource IconFont}" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="السابق" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button x:Name="NextPageButton" Click="NextPage_Click" Style="{StaticResource OutlineButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72B;" FontFamily="{StaticResource IconFont}" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="التالي" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
