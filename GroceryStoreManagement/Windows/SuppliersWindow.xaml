<UserControl x:Class="GroceryStoreManagement.Windows.SuppliersWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" FlowDirection="RightToLeft" Language="ar-YE" Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header & Stats -->
            <RowDefinition Height="Auto"/>
            <!-- Filters -->
            <RowDefinition Height="Auto"/>
            <!-- DataGrid -->
        </Grid.RowDefinitions>

        <!-- 1. Header & Stats -->
        <Grid Grid.Row="0" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="إدارة الموردين" Style="{StaticResource HeaderLabel}"/>
                <TextBlock Text="سجل بيانات الموردين والمشتريات" Style="{StaticResource BodyLabel}" Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Stats Cards -->
            <Grid Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="5,0" Padding="15">
                    <StackPanel>
                        <TextBlock Text="عدد الموردين" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="TotalSuppliersCountText" Text="0" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="5,0" Padding="15">
                    <StackPanel>
                        <TextBlock Text="إجمالي التوريد" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="TotalSuppliedValueText" Text="ر.ي 0" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource SecondaryBrush}" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- 2. Actions & Filter -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,20" Padding="15">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <Grid HorizontalAlignment="Left" MinWidth="820">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Add Button -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Search -->
                    <ColumnDefinition Width="*"/>
                    <!-- Spacer -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Actions -->
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnAddSupplier" Grid.Column="0" Click="AddSupplier_Click" Style="{StaticResource PrimaryButton}" Margin="0,0,20,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="{StaticResource IconFont}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="إضافة مورد" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Search -->
                <Grid Grid.Column="1" Margin="0,0,15,0" Width="250">
                    <TextBox x:Name="SearchTextBox" Style="{StaticResource ModernTextBox}" Padding="30,10,10,10" TextChanged="SearchTextBox_TextChanged"/>
                    <TextBlock Text="&#xE721;" FontFamily="{StaticResource IconFont}" FontSize="16" IsHitTestVisible="False" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" Foreground="{DynamicResource TextMutedBrush}"/>
                    <Button Click="SearchButton_Click" Visibility="Collapsed">
                        <TextBlock Text="&#xE721;" FontFamily="{StaticResource IconFont}"/>
                    </Button>
                </Grid>

                <!-- Actions -->
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button Click="RefreshButton_Click" Style="{StaticResource OutlineButton}" Margin="5,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="{StaticResource IconFont}" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Text="تحديث" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Click="Export_Click" Style="{StaticResource OutlineButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE749;" FontFamily="{StaticResource IconFont}" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Text="تصدير" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>

        <!-- 3. Table -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="0">
            <DataGrid x:Name="SuppliersGrid" Style="{StaticResource ModernDataGridStyle}" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="SuppliersGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding SupplierID}" Width="60" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTextColumn Header="الاسم" Binding="{Binding Name}" Width="*" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTextColumn Header="الهاتف" Binding="{Binding Phone}" Width="120" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTextColumn Header="البريد الإلكتروني" Binding="{Binding Email}" Width="150" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTextColumn Header="العنوان" Binding="{Binding Address}" Width="180" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTextColumn Header="عدد المنتجات" Binding="{Binding ProductCount}" Width="100" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTextColumn Header="قيمة التوريد" Binding="{Binding TotalSuppliedValue, StringFormat='{}{0:#,##0.##}'}" Width="120" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>

                    <DataGridTemplateColumn Header="الإجراءات" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Click="EditSupplier_Click" Tag="{Binding SupplierID}" Style="{StaticResource IconButton}" Margin="2">
                                        <TextBlock Text="&#xE70F;" FontFamily="{StaticResource IconFont}" FontSize="14"/>
                                    </Button>
                                    <Button Click="DeleteSupplier_Click" Tag="{Binding SupplierID}" Style="{StaticResource IconButton}" Foreground="{DynamicResource DangerBrush}" Margin="2">
                                        <TextBlock Text="&#xE74D;" FontFamily="{StaticResource IconFont}" FontSize="14"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

    </Grid>
</UserControl>



