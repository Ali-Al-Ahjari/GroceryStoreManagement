<Window x:Class="GroceryStoreManagement.Windows.ErrorLogsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="سجل الأخطاء" Height="600" Width="900" WindowStartupLocation="CenterOwner" WindowStyle="None" AllowsTransparency="True" Background="Transparent" ResizeMode="CanResize" FlowDirection="RightToLeft" Language="ar-YE" MaxHeight="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Height}" MaxWidth="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Width}">

    <Border CornerRadius="16" Background="{DynamicResource SurfaceBrush}" Effect="{DynamicResource CardShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- العنوان -->
            <Border Grid.Row="0" CornerRadius="16,16,0,0" Padding="20,15" MouseLeftButtonDown="Border_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#E74C3C" Offset="0"/>
                        <GradientStop Color="#C0392B" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7BA;" FontFamily="{StaticResource IconFont}" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="White"/>
                        <TextBlock Text="سجل الأخطاء" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button x:Name="BtnRefresh" Click="BtnRefresh_Click" Style="{StaticResource OutlineButton}" Foreground="White" BorderBrush="White" Padding="15,8" FontSize="12" Width="90" Margin="720,0,10,0" HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72C;" FontFamily="{StaticResource IconFont}" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="تحديث" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Click="BtnClose_Click" Style="{StaticResource IconButton}" Foreground="White">
                            <TextBlock Text="&#xE711;" FontFamily="{StaticResource IconFont}" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- محتوى السجل -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20">
                <TextBox x:Name="TxtLogContent" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" Background="{DynamicResource BackgroundBrush}" FontFamily="Consolas" FontSize="12" Padding="15" BorderThickness="0"/>
            </ScrollViewer>

            <!-- شريط الإجراءات -->
            <Border Grid.Row="2" BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,1,0,0" Padding="20,15">
                <Grid>
                    <TextBlock x:Name="TxtLogInfo" Text="ملف السجل: --" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Width="200" Margin="284,0,376,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button x:Name="BtnOpenFolder" Click="BtnOpenFolder_Click" Style="{StaticResource OutlineButton}" Padding="15,8" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8D5;" FontFamily="{StaticResource IconFont}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="فتح المجلد" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnClearLogs" Click="BtnClearLogs_Click" Style="{StaticResource OutlineButton}" Foreground="{DynamicResource ErrorBrush}" Padding="15,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74D;" FontFamily="{StaticResource IconFont}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock Text="مسح السجل" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Border>

</Window>
