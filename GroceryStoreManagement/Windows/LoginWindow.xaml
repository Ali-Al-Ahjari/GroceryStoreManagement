<Window x:Class="GroceryStoreManagement.Windows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تسجيل الدخول - نظام إدارة المتجر" 
        Height="{StaticResource WindowHeightLogin}" 
        Width="{StaticResource WindowWidthLogin}" 
        WindowStartupLocation="CenterScreen" 
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent" 
        ResizeMode="NoResize" 
        FlowDirection="RightToLeft" 
        Language="ar-YE">

    <Window.Resources>
        <!-- أنماط أزرار الترخيص المتوافقة مع نظام التصميم -->
        <Style x:Key="LicenseActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextLightBrush}"/>
            <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="{StaticResource FontWeightSemiBold}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="MainActionBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusControlSmall}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainActionBorder" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="MainActionBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97" CenterX="50" CenterY="14"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="MainActionBorder" Property="Background" Value="{DynamicResource BrushDisabledBackground}"/>
                                <Setter TargetName="MainActionBorder" Property="BorderBrush" Value="{DynamicResource BrushDisabledBorder}"/>
                                <Setter Property="Foreground" Value="{DynamicResource BrushDisabledText}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LicenseSecondaryButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="{StaticResource FontWeightSemiBold}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SecondaryActionBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="{StaticResource CornerRadiusControlSmall}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SecondaryActionBorder" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="SecondaryActionBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97" CenterX="50" CenterY="14"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="SecondaryActionBorder" Property="Background" Value="{DynamicResource BrushDisabledBackground}"/>
                                <Setter TargetName="SecondaryActionBorder" Property="BorderBrush" Value="{DynamicResource BrushDisabledBorder}"/>
                                <Setter Property="Foreground" Value="{DynamicResource BrushDisabledText}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LoginInputBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusControlNormal}"/>
            <Setter Property="Height" Value="42"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                    <Setter Property="BorderThickness" Value="1.5"/>
                    <Setter Property="Background" Value="{DynamicResource BrushInputFocusBg}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- واجهة الدخول المصممة بمفهوم Windows 11 Fluent Design -->
    <Border x:Name="MainRoot" Background="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Direction="270" Opacity="0.3" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>  <!-- شريط العنوان المخصص -->
                <RowDefinition Height="*"/>   <!-- محتوى النافذة الرئيسي -->
            </Grid.RowDefinitions>

            <!-- ═══════════════════════════════════════════════════════════════════════════════ -->
            <!-- شريط العنوان المخصص (Custom Title Bar) -->
            <!-- ═══════════════════════════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="0" x:Name="TitleBarGrid" Background="Transparent" MouseLeftButtonDown="DragWindow">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- أزرار التحكم باليسار -->
                    <ColumnDefinition Width="*"/>    <!-- مساحة فارغة للسحب -->
                    <ColumnDefinition Width="Auto"/> <!-- أيقونة وعنوان البرنامج باليمين -->
                </Grid.ColumnDefinitions>

                <!-- أزرار الإعدادات والإغلاق باليسار -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0" FlowDirection="LeftToRight">
                    <!-- زر الإغلاق -->
                    <Button x:Name="BtnExit" Width="32" Height="24" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextSecondaryBrush}" Click="BtnExit_Click" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="CloseBorder" Background="{TemplateBinding Background}" CornerRadius="4">
                                                <TextBlock Text="&#xE711;" FontFamily="{StaticResource IconFont}" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#C42B1C"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- زر الإعدادات -->
                    <Button x:Name="BtnSettings" Width="32" Height="24" Margin="4,0,0,0" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextSecondaryBrush}" Click="BtnSettings_Click" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="SettingsBorder" Background="{TemplateBinding Background}" CornerRadius="4">
                                                <TextBlock Text="&#xE713;" FontFamily="{StaticResource IconFont}" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource BorderLightBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- أيقونة وعنوان باليمين -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock Text="&#xE719;" FontFamily="{StaticResource IconFont}" FontSize="12" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="نظام إدارة المتجر" FontFamily="{StaticResource PrimaryFont}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- ═══════════════════════════════════════════════════════════════════════════════ -->
            <!-- محتوى النموذج الرئيسي (LoginFormPanel) -->
            <!-- ═══════════════════════════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="1" x:Name="LoginFormPanel">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="28,8,28,24">

                        <!-- ترويسة الشعار والترحيب -->
                        <StackPanel x:Name="BrandingPanel" HorizontalAlignment="Center" Margin="0,10,0,16">
                            <Border Width="64" Height="64" Background="{DynamicResource BrushAccentMuted}" CornerRadius="16" HorizontalAlignment="Center" Margin="0,0,0,12">
                                <TextBlock Text="&#xE719;" FontFamily="{StaticResource IconFont}" FontSize="32" Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="مرحباً بعودتك!" FontFamily="{StaticResource PrimaryFont}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="سجّل الدخول للوصول إلى لوحة التحكم وإدارة عمليات المتجر" FontFamily="{StaticResource PrimaryFont}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,6,0,0" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- بطاقة حالة الترخيص -->
                        <Border x:Name="LicenseCard" CornerRadius="{StaticResource CornerRadiusControlNormal}" BorderThickness="1" BorderBrush="{DynamicResource SuccessBrush}" Background="{DynamicResource SuccessBrushMuted}" Padding="12" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel VerticalAlignment="Center">
                                    <DockPanel LastChildFill="False">
                                        <TextBlock Text="&#xE8D7;" FontFamily="{StaticResource IconFont}" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="{DynamicResource SuccessBrush}"/>
                                        <TextBlock Text="حالة الترخيص" Foreground="{DynamicResource SuccessBrush}" FontWeight="SemiBold" FontSize="{StaticResource FontSizeCaption}" FontFamily="{StaticResource PrimaryFont}" VerticalAlignment="Center"/>
                                        <Border x:Name="LicenseStateBadge" Background="{DynamicResource SuccessBrush}" CornerRadius="4" Padding="6,1" Margin="8,0,0,0">
                                            <TextBlock x:Name="TxtLicenseStateBadge" Text="جاري الفحص" Foreground="White" FontWeight="SemiBold" FontSize="10"/>
                                        </Border>
                                    </DockPanel>

                                    <TextBlock x:Name="TxtLicenseStatus" Text="جاري التحقق..." Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap" FontFamily="{StaticResource PrimaryFont}"/>
                                    <TextBlock x:Name="TxtLicenseExpiry" Text="..." Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10.5" Margin="0,4,0,0" TextWrapping="Wrap" FontFamily="{StaticResource PrimaryFont}"/>
                                    <TextBlock x:Name="TxtMachineFingerprint" Foreground="{DynamicResource TextMutedBrush}" FontSize="9.5" Margin="0,4,0,0" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" FontFamily="{StaticResource PrimaryFont}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <Button x:Name="BtnLicenseActivation" Width="100" Height="28" Style="{StaticResource LicenseActionButtonStyle}" Click="BtnLicenseActivation_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8D7;" FontFamily="{StaticResource IconFont}" FontSize="10" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtLicenseActionLabel" Text="تفعيل الآن" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="BtnCopyMachineFingerprint" Width="100" Height="28" Margin="0,6,0,0" Style="{StaticResource LicenseSecondaryButtonStyle}" Click="BtnCopyMachineFingerprint_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8C8;" FontFamily="{StaticResource IconFont}" FontSize="10" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="نسخ البصمة" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- حقل اسم المستخدم -->
                        <TextBlock Text="اسم المستخدم" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold" FontFamily="{StaticResource PrimaryFont}" FontSize="12.5" Margin="0,0,0,6"/>
                        <Border Style="{StaticResource LoginInputBorderStyle}" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE77B;" FontFamily="{StaticResource IconFont}" Margin="12,0,4,0" VerticalAlignment="Center" FontSize="14" Foreground="{DynamicResource TextMutedBrush}"/>
                                <TextBox x:Name="TxtUsername" Grid.Column="1" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" FontSize="{StaticResource FontSizeBody}" FontFamily="{StaticResource PrimaryFont}" Padding="4,0,8,0" KeyDown="TxtUsername_KeyDown"/>
                            </Grid>
                        </Border>

                        <!-- حقل كلمة المرور -->
                        <TextBlock Text="كلمة المرور" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold" FontFamily="{StaticResource PrimaryFont}" FontSize="12.5" Margin="0,0,0,6"/>
                        <Border Style="{StaticResource LoginInputBorderStyle}" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="&#xE72E;" FontFamily="{StaticResource IconFont}" Margin="12,0,4,0" VerticalAlignment="Center" FontSize="14" Foreground="{DynamicResource TextMutedBrush}"/>

                                <PasswordBox x:Name="TxtPassword" Grid.Column="1" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" FontSize="{StaticResource FontSizeBody}" FontFamily="{StaticResource PrimaryFont}" Padding="4,0,8,0" PasswordChar="●" KeyDown="TxtPassword_KeyDown" PasswordChanged="TxtPassword_PasswordChanged"/>

                                <TextBox x:Name="TxtPasswordVisible" Grid.Column="1" Visibility="Collapsed" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" FontSize="{StaticResource FontSizeBody}" FontFamily="{StaticResource PrimaryFont}" Padding="4,0,8,0" KeyDown="TxtPassword_KeyDown" TextChanged="TxtPasswordVisible_TextChanged"/>

                                <Button x:Name="BtnShowPassword" Grid.Column="2" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextMutedBrush}" Cursor="Hand" Width="36" Click="BtnShowPassword_Click">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="Transparent">
                                                            <TextBlock x:Name="IconEye" Text="&#xE890;" FontFamily="{StaticResource IconFont}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" Foreground="{TemplateBinding Foreground}"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- خيار نسيت كلمة المرور -->
                        <Button x:Name="BtnForgotPassword" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource PrimaryBrush}" FontFamily="{StaticResource PrimaryFont}" FontSize="11" Cursor="Hand" Margin="0,0,0,20" Click="BtnForgotPassword_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72E;" FontFamily="{StaticResource IconFont}" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock Text="نسيت كلمة المرور؟" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- زر تسجيل الدخول -->
                        <Button x:Name="BtnLogin" Height="42" FontSize="14" FontWeight="Bold" FontFamily="{StaticResource PrimaryFont}" Foreground="White" Cursor="Hand" Click="BtnLogin_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE77B;" FontFamily="{StaticResource IconFont}" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="تسجيل الدخول" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="{DynamicResource PrimaryGradient}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="{StaticResource CornerRadiusControlNormal}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Opacity" Value="0.92"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="border" Property="RenderTransform">
                                                            <Setter.Value>
                                                                <ScaleTransform ScaleX="0.98" ScaleY="0.98" CenterX="170" CenterY="21"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="border" Property="Background" Value="{DynamicResource BrushDisabledBackground}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource BrushDisabledText}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <Button.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Direction="270" Opacity="0.2" Color="{DynamicResource ColorAccentPrimary}"/>
                            </Button.Effect>
                        </Button>

                        <!-- حقوق النشر -->
                        <TextBlock Text="© 2026 جميع الحقوق محفوظة" HorizontalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" FontFamily="{StaticResource PrimaryFont}" FontSize="10.5" Margin="0,24,0,0"/>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
