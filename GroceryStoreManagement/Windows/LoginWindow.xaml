<Window x:Class="GroceryStoreManagement.Windows.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="تسجيل الدخول - نظام إدارة المتجر" Height="730" Width="1140" WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True" Background="Transparent" ResizeMode="NoResize" FlowDirection="RightToLeft" Language="ar-YE" MaxHeight="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Height}" MaxWidth="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Width}">

    <Window.Resources>
        <Style x:Key="LoginInputBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BrushSurfaceCore}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorderDefault}"/>
            <Setter Property="BorderThickness" Value="1.4"/>
            <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusControlLarge}"/>
            <Setter Property="Height" Value="54"/>
            <Setter Property="Effect" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource BrushSuccess}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                    <Setter Property="Background" Value="{StaticResource BrushAccentMuted}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LicenseActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource BrushTextLight}"/>
            <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
            <Setter Property="FontWeight" Value="{StaticResource FontWeightSemiBold}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{StaticResource BrushAccentPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushAccentPrimary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="MainActionBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="{StaticResource CornerRadiusControlSmall}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainActionBorder" Property="Opacity" Value="0.93"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="MainActionBorder" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="MainActionBorder" Property="Background" Value="#CBD5E1"/>
                                <Setter TargetName="MainActionBorder" Property="BorderBrush" Value="#CBD5E1"/>
                                <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LicenseSecondaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource BrushAccentPrimary}"/>
            <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
            <Setter Property="FontWeight" Value="{StaticResource FontWeightSemiBold}"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{StaticResource BrushSurfaceCore}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorderDefault}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SecondaryActionBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="{StaticResource CornerRadiusControlSmall}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SecondaryActionBorder" Property="Background" Value="#F0F9F7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="SecondaryActionBorder" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="SecondaryActionBorder" Property="Background" Value="#F1F5F9"/>
                                <Setter TargetName="SecondaryActionBorder" Property="BorderBrush" Value="#D5DEE7"/>
                                <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- =========================================================================== -->
    <!-- LoginWindow.xaml - تصميم جديد نظيف وأنيق                                  -->
    <!-- =========================================================================== -->

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{StaticResource ColorSidebarBackground}" Offset="0"/>
                <GradientStop Color="{StaticResource ColorSidebarHover}" Offset="0.55"/>
                <GradientStop Color="{StaticResource ColorAccentPrimary}" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Canvas IsHitTestVisible="False">
            <Ellipse Width="540" Height="540" Fill="#26FFFFFF" Canvas.Left="-170" Canvas.Top="-220"/>
            <Ellipse Width="460" Height="460" Fill="#11FFFFFF" Canvas.Right="-90" Canvas.Top="-80"/>
            <Ellipse Width="360" Height="360" Fill="#16FFFFFF" Canvas.Left="760" Canvas.Top="430"/>
        </Canvas>

        <!-- طبقة خلفية شفافة لتمكين سحب النافذة -->
        <Border Background="#00FFFFFF" MouseLeftButtonDown="DragWindow"/>

        <!-- البطاقة الرئيسية العائمة -->
        <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
            <Border x:Name="MainRoot" Width="980" Height="610" CornerRadius="30" Background="{StaticResource BrushBackgroundHeader}" BorderBrush="{StaticResource BrushBorderDefault}" BorderThickness="1" VerticalAlignment="Center" HorizontalAlignment="Center">

            <Border.Effect>
                <StaticResource ResourceKey="ElevationShadowHigh"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="390" />
                    <!-- قسم العلامة التجارية -->
                    <ColumnDefinition Width="*" />
                    <!-- قسم النموذج -->
                </Grid.ColumnDefinitions>

                <!-- ======================================================================= -->
                <!-- العمود الأيمن (في العربية): العلامة التجارية الجذابة                     -->
                <!-- ======================================================================= -->
                <Border x:Name="BrandingPanel" Grid.Column="0" CornerRadius="0,30,30,0" Height="610">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{StaticResource ColorAccentPrimary}" Offset="0"/>
                            <GradientStop Color="{StaticResource ColorSidebarBackground}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>

                    <Grid ClipToBounds="True">
                        <Ellipse Width="420" Height="420" Fill="#22FFFFFF" Margin="-140,-120,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <Ellipse Width="260" Height="260" Fill="#17FFFFFF" Margin="0,0,-80,-100" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                        <Rectangle Width="220" Height="220" Fill="#10FFFFFF" RadiusX="36" RadiusY="36" RenderTransformOrigin="0.5,0.5" Margin="0,240,-140,0" HorizontalAlignment="Right">
                            <Rectangle.RenderTransform>
                                <RotateTransform Angle="-18"/>
                            </Rectangle.RenderTransform>
                        </Rectangle>

                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="36">
                            <Border Width="112" Height="112" Background="#24FFFFFF" CornerRadius="34" Margin="0,0,0,28">
                                <TextBlock Text="&#xE719;" FontFamily="{StaticResource IconFont}" FontSize="56" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" />
                            </Border>

                            <TextBlock Text="نظام إدارة المتجر" FontFamily="{StaticResource PrimaryFont}" FontSize="{StaticResource FontSizeTitleLarge}" FontWeight="{StaticResource FontWeightBold}" Foreground="White" HorizontalAlignment="Center"/>

                            <TextBlock Text="واجهات أسرع، أوضح، وأكثر احترافية لإدارة يومك بالكامل" FontFamily="{StaticResource PrimaryFont}" FontSize="{StaticResource FontSizeBody}" Foreground="{StaticResource BrushAccentMuted}" Opacity="0.95" TextWrapping="Wrap" TextAlignment="Center" Margin="0,16,0,0"/>

                            <StackPanel Margin="0,34,0,0">
                                <TextBlock Text="• متابعة المبيعات والحركة مباشرة" Foreground="{StaticResource BrushAccentMuted}" FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,8"/>
                                <TextBlock Text="• تسريع الوصول للعمليات اليومية" Foreground="{StaticResource BrushAccentMuted}" FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,8"/>
                                <TextBlock Text="• تجربة أنظف لكل المستخدمين" Foreground="{StaticResource BrushAccentMuted}" FontSize="{StaticResource FontSizeBody}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ======================================================================= -->
                <!-- العمود الأيسر (في العربية): نموذج تسجيل الدخول النظيف                    -->
                <!-- ======================================================================= -->
                <Grid x:Name="LoginFormPanel" Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- أزرار التحكم العلوية -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="22,18,22,0" FlowDirection="LeftToRight">
                        <Button x:Name="BtnExit" Foreground="#64748B" Background="#00FFFFFF" BorderThickness="0" Width="36" Height="36" Click="BtnExit_Click" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="{StaticResource CornerRadiusControlSmall}">
                                                    <TextBlock Text="&#xE711;" FontFamily="{StaticResource IconFont}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource BrushBorderDefault}"/>
                                            <Setter Property="Foreground" Value="{StaticResource BrushError}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button x:Name="BtnSettings" Foreground="#64748B" Background="#00FFFFFF" BorderThickness="0" Width="36" Height="36" Margin="10,0,0,0" Click="BtnSettings_Click" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="{StaticResource CornerRadiusControlSmall}">
                                                    <TextBlock Text="&#xE713;" FontFamily="{StaticResource IconFont}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource BrushBorderDefault}"/>
                                            <Setter Property="Foreground" Value="{StaticResource BrushAccentPrimary}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- منطقة النموذج -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="70,0">

                        <TextBlock Text="مرحباً بعودتك!" FontFamily="{StaticResource PrimaryFont}" FontSize="{StaticResource FontSizeTitleLarge}" FontWeight="{StaticResource FontWeightBold}" Foreground="{StaticResource BrushTextPrimary}" Margin="0,0,0,8"/>

                        <TextBlock Text="سجّل الدخول للوصول إلى لوحة التحكم وإدارة عمليات المتجر" FontFamily="{StaticResource PrimaryFont}" FontSize="{StaticResource FontSizeBody}" Foreground="{StaticResource BrushTextSecondary}" Margin="0,0,0,18"/>

                        <Border x:Name="LicenseCard" CornerRadius="{StaticResource CornerRadiusControlLarge}" BorderThickness="1" BorderBrush="{StaticResource BrushSuccess}" Background="{StaticResource BrushAccentMuted}" Padding="12" Margin="0,0,0,18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <DockPanel LastChildFill="False">
                                        <TextBlock Text="&#xE8D7;" FontFamily="{StaticResource IconFont}" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="#166534"/>
                                        <TextBlock Text="حالة الترخيص" Foreground="{StaticResource BrushSuccess}" FontWeight="{StaticResource FontWeightBold}" FontSize="{StaticResource FontSizeCaption}" FontFamily="{StaticResource PrimaryFont}" VerticalAlignment="Center"/>
                                        <Border x:Name="LicenseStateBadge" Background="{StaticResource BrushSuccess}" BorderBrush="{StaticResource BrushSuccess}" BorderThickness="1" CornerRadius="7" Padding="8,2" Margin="8,0,0,0">
                                            <TextBlock x:Name="TxtLicenseStateBadge" Text="جاري الفحص" Foreground="White" FontWeight="SemiBold" FontSize="10.5"/>
                                        </Border>
                                    </DockPanel>

                                    <TextBlock x:Name="TxtLicenseStatus" Text="جاري التحقق..." Foreground="{StaticResource BrushSuccess}" FontSize="{StaticResource FontSizeCaption}" Margin="0,6,0,0" TextWrapping="Wrap" FontFamily="{StaticResource PrimaryFont}"/>

                                    <TextBlock x:Name="TxtLicenseExpiry" Text="..." Foreground="{StaticResource BrushSuccess}" FontSize="{StaticResource FontSizeCaption}" Margin="0,4,0,0" TextWrapping="Wrap" FontFamily="{StaticResource PrimaryFont}"/>

                                    <TextBlock x:Name="TxtMachineFingerprint" Foreground="{StaticResource BrushTextSecondary}" FontSize="{StaticResource FontSizeCaption}" Margin="0,4,0,0" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" FontFamily="{StaticResource PrimaryFont}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <Button x:Name="BtnLicenseActivation" Width="132" Style="{StaticResource LicenseActionButtonStyle}" Click="BtnLicenseActivation_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8D7;" FontFamily="{StaticResource IconFont}" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtLicenseActionLabel" Text="تفعيل الآن" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="BtnCopyMachineFingerprint" Width="132" Margin="0,8,0,0" Style="{StaticResource LicenseSecondaryButtonStyle}" Click="BtnCopyMachineFingerprint_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8C8;" FontFamily="{StaticResource IconFont}" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="نسخ البصمة" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- حقل اسم المستخدم -->
                        <TextBlock Text="اسم المستخدم" Foreground="{StaticResource BrushTextSecondary}" FontWeight="{StaticResource FontWeightSemiBold}" FontFamily="{StaticResource PrimaryFont}" FontSize="{StaticResource FontSizeBody}" Margin="{StaticResource MarginStackSmall}"/>

                        <Border Style="{StaticResource LoginInputBorderStyle}" Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE77B;" FontFamily="{StaticResource IconFont}" Margin="16,0,6,0" VerticalAlignment="Center" FontSize="17" Opacity="0.72"/>
                                <TextBox x:Name="TxtUsername" Grid.Column="1" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" FontSize="{StaticResource FontSizeBody}" FontFamily="{StaticResource PrimaryFont}" Padding="6,0,12,0" KeyDown="TxtUsername_KeyDown"/>
                            </Grid>
                        </Border>

                        <!-- حقل كلمة المرور -->
                        <TextBlock Text="كلمة المرور" Foreground="{StaticResource BrushTextSecondary}" FontWeight="{StaticResource FontWeightSemiBold}" FontFamily="{StaticResource PrimaryFont}" FontSize="{StaticResource FontSizeBody}" Margin="{StaticResource MarginStackSmall}"/>

                        <Border Style="{StaticResource LoginInputBorderStyle}" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="&#xE72E;" FontFamily="{StaticResource IconFont}" Margin="16,0,6,0" VerticalAlignment="Center" FontSize="17" Opacity="0.72"/>

                                <PasswordBox x:Name="TxtPassword" Grid.Column="1" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" FontSize="{StaticResource FontSizeBody}" FontFamily="{StaticResource PrimaryFont}" Padding="6,0,12,0" PasswordChar="●" KeyDown="TxtPassword_KeyDown" PasswordChanged="TxtPassword_PasswordChanged"/>

                                <TextBox x:Name="TxtPasswordVisible" Grid.Column="1" Visibility="Collapsed" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" FontSize="{StaticResource FontSizeBody}" FontFamily="{StaticResource PrimaryFont}" Padding="6,0,12,0" KeyDown="TxtPassword_KeyDown" TextChanged="TxtPasswordVisible_TextChanged"/>

                                <Button x:Name="BtnShowPassword" Grid.Column="2" Background="Transparent" BorderThickness="0" Foreground="#64748B" Cursor="Hand" Width="42" Click="BtnShowPassword_Click">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="Transparent">
                                                            <TextBlock x:Name="IconEye" Text="&#xE890;" FontFamily="{StaticResource IconFont}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Foreground="{TemplateBinding Foreground}"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- نسيت كلمة المرور -->
                        <Button x:Name="BtnForgotPassword" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Foreground="{StaticResource BrushAccentPrimary}" FontFamily="{StaticResource PrimaryFont}" FontSize="{StaticResource FontSizeCaption}" Cursor="Hand" Margin="0,0,0,30" Click="BtnForgotPassword_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72E;" FontFamily="{StaticResource IconFont}" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="نسيت كلمة المرور؟" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- زر الدخول -->
                        <Button x:Name="BtnLogin" Height="56" FontSize="{StaticResource FontSizeSubHeader}" FontWeight="{StaticResource FontWeightBold}" FontFamily="{StaticResource PrimaryFont}" Foreground="White" Cursor="Hand" Click="BtnLogin_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE77B;" FontFamily="{StaticResource IconFont}" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="تسجيل الدخول" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="{StaticResource ColorAccentPrimary}" Offset="0"/>
                                                <GradientStop Color="{StaticResource ColorAccentLight}" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="{StaticResource CornerRadiusControlLarge}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Opacity" Value="0.94"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="border" Property="Opacity" Value="0.82"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <Button.Effect>
                                <StaticResource ResourceKey="AccentShadow"/>
                            </Button.Effect>
                        </Button>

                    </StackPanel>

                    <!-- الحقوق -->
                    <TextBlock Grid.Row="2" Text="© 2026 جميع الحقوق محفوظة" HorizontalAlignment="Center" Foreground="{StaticResource BrushTextMuted}" FontFamily="{StaticResource PrimaryFont}" FontSize="{StaticResource FontSizeCaption}" Margin="0,0,0,20"/>
                </Grid>
            </Grid>
            </Border>
        </Viewbox>
    </Grid>
</Window>
