<Window x:Class="GroceryStoreManagement.Windows.PaymentDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="سداد دفعة" Height="700" Width="500" WindowStartupLocation="CenterOwner" WindowStyle="None" AllowsTransparency="True" Background="Transparent" ResizeMode="NoResize" FlowDirection="RightToLeft" Language="ar-YE" ShowInTaskbar="False" MaxHeight="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Height}" MaxWidth="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Width}">

    <Border CornerRadius="16" Background="{DynamicResource SurfaceBrush}" Effect="{DynamicResource CardShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource SecondaryGradient}" CornerRadius="16,16,0,0" Padding="20,15" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid FlowDirection="LeftToRight">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Click="CloseButton_Click" Style="{StaticResource IconButton}" Foreground="White">
                        <TextBlock Text="&#xE711;" FontFamily="{StaticResource IconFont}" />
                    </Button>
                    <TextBlock Grid.Column="1" Text="💰 سداد دفعة" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Center" FlowDirection="RightToLeft"/>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="25,20">
                <StackPanel>

                    <!-- Info Box -->
                    <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="10" Padding="15" Margin="0,0,0,20">
                        <Grid Grid.IsSharedSizeScope="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="PaymentInfoLabel"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*" SharedSizeGroup="PaymentInfoValue"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="رقم الفاتورة:" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" x:Name="InvoiceNumberText" FontWeight="Bold" TextAlignment="Left" FlowDirection="LeftToRight"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="العميل:" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,10,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" x:Name="CustomerNameText" FontWeight="Bold" Margin="0,10,0,0"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="الإجمالي:" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,10,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" x:Name="TotalAmountText" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" TextAlignment="Left" FlowDirection="LeftToRight" Margin="0,10,0,0"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="المدفوع:" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,10,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" x:Name="PaidAmountText" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}" TextAlignment="Left" FlowDirection="LeftToRight" Margin="0,10,0,0"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="المتبقي:" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,10,0,0"/>
                            <TextBlock Grid.Row="4" Grid.Column="2" x:Name="RemainingAmountText" FontWeight="Bold" Foreground="{DynamicResource ErrorBrush}" TextAlignment="Left" FlowDirection="LeftToRight" Margin="0,10,0,0"/>
                        </Grid>
                    </Border>

                    <TextBlock Text="مبلغ الدفع" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="PaymentAmountTextBox" Style="{StaticResource ModernTextBox}" FontSize="20" FontWeight="Bold" TextAlignment="Center" FlowDirection="LeftToRight" TextChanged="PaymentAmountTextBox_TextChanged"/>

                    <Grid Margin="0,12,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Click="PayFullAmount_Click" Style="{StaticResource OutlineButton}" FontSize="11">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8A5;" FontFamily="{StaticResource IconFont}" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock Text="دفع المتبقي كاملاً" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" Click="PayHalfAmount_Click" Style="{StaticResource OutlineButton}" FontSize="11">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8A5;" FontFamily="{StaticResource IconFont}" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock Text="دفع نصف المتبقي" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <TextBlock Text="طريقة الدفع" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="PaymentMethodComboBox" Style="{StaticResource ModernComboBox}">
                        <ComboBoxItem Content="نقدي" Tag="Cash" IsSelected="True"/>
                        <ComboBoxItem Content="بطاقة ائتمان" Tag="Card"/>
                        <ComboBoxItem Content="تحويل بنكي" Tag="Transfer"/>
                        <ComboBoxItem Content="شيك" Tag="Check"/>
                    </ComboBox>

                    <TextBlock Text="ملاحظات" Style="{StaticResource LabelStyle}" Margin="0,10,0,5"/>
                    <TextBox x:Name="NotesTextBox" Style="{StaticResource ModernTextBox}" Height="44"/>

                </StackPanel>
            </ScrollViewer>

            <!-- Actions -->
            <Border Grid.Row="2" BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,1,0,0" Padding="20,15">
                <Grid HorizontalAlignment="Right">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" x:Name="SaveButton" Click="SavePayment_Click" Style="{StaticResource SecondaryButton}" Padding="25,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE73E;" FontFamily="{StaticResource IconFont}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Text="تأكيد الدفع" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2" Click="CloseButton_Click" Style="{StaticResource OutlineButton}" Padding="25,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE711;" FontFamily="{StaticResource IconFont}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Text="إلغاء" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>

</Window>
