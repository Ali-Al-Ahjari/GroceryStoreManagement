<Window x:Class="GroceryStoreManagement.Windows.NotificationsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="الإشعارات" Height="500" Width="600" WindowStartupLocation="CenterOwner" WindowStyle="None" AllowsTransparency="True" Background="Transparent" ResizeMode="NoResize" FlowDirection="RightToLeft" Language="ar-YE" MaxHeight="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Height}" MaxWidth="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Width}">

    <Border CornerRadius="16" Background="{DynamicResource SurfaceBrush}" Effect="{DynamicResource CardShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- العنوان -->
            <Border Grid.Row="0" Background="{DynamicResource PrimaryGradient}" CornerRadius="16,16,0,0" Padding="20,15" MouseLeftButtonDown="DragWindow">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xEA8F;" FontFamily="{StaticResource IconFont}" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="White"/>
                        <TextBlock Text="جميع الإشعارات" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="BtnMarkAllRead" Background="Transparent" BorderThickness="0" Foreground="White" FontSize="11" FontWeight="SemiBold" Cursor="Hand" Click="BtnMarkAllRead_Click" Margin="0,0,16,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE73E;" FontFamily="{StaticResource IconFont}" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock Text="تحديد الكل كمقروء" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Click="BtnClose_Click" Style="{StaticResource IconButton}" Foreground="White" VerticalAlignment="Center">
                            <TextBlock Text="&#xE711;" FontFamily="{StaticResource IconFont}" FontSize="12"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- قائمة الإشعارات -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <ItemsControl x:Name="NotificationsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="20,15" BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,0,0,1" Background="{Binding BackgroundColor}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Background="{DynamicResource BackgroundBrush}" Margin="0,0,15,0">
                                            <TextBlock Text="{Binding Icon}" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Message}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding CreatedAtDisplay}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <Button Grid.Column="2" Click="BtnDelete_Click" Tag="{Binding NotificationID}" Style="{StaticResource IconButton}" Width="32" Height="32">
                                            <TextBlock Text="&#xE74D;" FontFamily="{StaticResource IconFont}" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="EmptyMessage" Text="لا توجد إشعارات" FontSize="14" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" Margin="30" Visibility="Collapsed"/>
                </StackPanel>
            </ScrollViewer>

            <!-- شريط الإجراءات -->
            <Border Grid.Row="2" BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,1,0,0" Padding="20,15">
                <Grid>
                    <TextBlock x:Name="TxtCount" Text="0 إشعار" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Width="300"/>
                    <Button x:Name="BtnClearAll" Click="BtnClearAll_Click" Style="{StaticResource OutlineButton}" Foreground="{DynamicResource ErrorBrush}" HorizontalAlignment="Left" Padding="15,8" Margin="0,3,0,-3">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74D;" FontFamily="{StaticResource IconFont}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Text="حذف الكل" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

        </Grid>
    </Border>

</Window>
