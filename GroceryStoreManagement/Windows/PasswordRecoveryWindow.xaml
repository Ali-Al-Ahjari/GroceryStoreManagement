<Window x:Class="GroceryStoreManagement.Windows.PasswordRecoveryWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="استعادة كلمة المرور" Height="400" Width="420" WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True" Background="Transparent" ResizeMode="NoResize" FlowDirection="RightToLeft" Language="ar-YE" MaxHeight="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Height}" MaxWidth="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Width}">

    <Border CornerRadius="16" Background="{StaticResource SurfaceBrush}" Effect="{StaticResource CardShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- العنوان -->
            <Border Grid.Row="0" Background="{StaticResource PrimaryGradient}" CornerRadius="16,16,0,0" Padding="20,15">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8D7;" FontFamily="{StaticResource IconFont}" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="White"/>
                        <TextBlock Text="استعادة كلمة المرور" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Click="BtnClose_Click" Style="{StaticResource IconButton}" Foreground="White" HorizontalAlignment="Left" Margin="340,0,0,0">
                        <TextBlock Text="&#xE711;" FontFamily="{StaticResource IconFont}" />
                    </Button>
                </Grid>
            </Border>

            <!-- المحتوى -->
            <StackPanel Grid.Row="1" Margin="25,20">

                <TextBlock Text="أدخل اسم المستخدم للتحقق من هويتك" Foreground="{StaticResource TextSecondaryBrush}" TextAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="اسم المستخدم" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBox x:Name="TxtUsername" Style="{StaticResource ModernTextBox}" FlowDirection="LeftToRight" TextAlignment="Right" Margin="0,0,0,15"/>

                <TextBlock Text="البريد الإلكتروني" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBox x:Name="TxtEmail" Style="{StaticResource ModernTextBox}" FlowDirection="LeftToRight" TextAlignment="Right" Margin="0,0,0,20"/>

                <Border x:Name="MessagePanel" Background="{StaticResource BackgroundBrush}" CornerRadius="10" Padding="15" Visibility="Collapsed">
                    <TextBlock x:Name="TxtMessage" TextWrapping="Wrap" TextAlignment="Center"/>
                </Border>

            </StackPanel>

            <!-- أزرار الإجراءات -->
            <Border Grid.Row="2" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,1,0,0" Padding="20,15">
                <Grid>
                    <Button x:Name="BtnBack" Style="{StaticResource OutlineButton}" HorizontalAlignment="Right" Padding="20,10" Click="BtnBack_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7A7;" FontFamily="{StaticResource IconFont}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Text="العودة" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnSubmit" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" Padding="20,10" Click="BtnSubmit_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE73E;" FontFamily="{StaticResource IconFont}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Text="إرسال طلب الاستعادة" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

        </Grid>
    </Border>

</Window>
