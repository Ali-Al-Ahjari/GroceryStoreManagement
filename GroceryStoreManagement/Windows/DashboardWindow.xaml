<UserControl x:Class="GroceryStoreManagement.Windows.DashboardWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" FlowDirection="RightToLeft" Language="ar-YE" Background="{StaticResource BackgroundBrush}" Loaded="UserControl_Loaded" Unloaded="UserControl_Unloaded">

    <!--
    ═══════════════════════════════════════════════════════════════════════════════
    DashboardWindow.xaml - لوحة التحكم الرئيسية
    تعرض ملخص الإحصائيات والرسوم البيانية والتنبيهات
    ═══════════════════════════════════════════════════════════════════════════════
    -->

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ═══════════════════════════════════════════════════════════════════════════════ -->
            <!-- العنوان وزر التحديث -->
            <!-- ═══════════════════════════════════════════════════════════════════════════════ -->
            <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,30" Padding="26,22">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="مرحباً بك في لوحة التحكم 👋" Style="{StaticResource HeaderLabel}"/>
                        <TextBlock Text="إليك نظرة شاملة وفورية على حركة المتجر اليوم" Style="{StaticResource BodyLabel}" Margin="0,8,0,0"/>
                        <Border Background="#E8F3F2" CornerRadius="10" Padding="10,6" HorizontalAlignment="Left" Margin="0,14,0,0">
                            <TextBlock Text="وضع التشغيل: مباشر" FontFamily="{StaticResource PrimaryFont}" Foreground="{StaticResource PrimaryDarkBrush}" FontSize="12" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>

                    <Button Grid.Column="1" Style="{StaticResource OutlineButton}" Padding="22,11" FontSize="13" VerticalAlignment="Top" Click="RefreshDashboard_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="{StaticResource IconFont}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Text="تحديث البيانات" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════════════════════════ -->
            <!-- أزرار الإجراءات السريعة (محسنة) -->
            <!-- ═══════════════════════════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="1" Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- فاتورة جديدة -->
                <Button Grid.Column="0" Click="QuickAddInvoice_Click" Cursor="Hand" Background="Transparent" BorderThickness="0" Padding="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Style="{StaticResource CardBorder}" Padding="14,22" Background="#FCFEFF">
                                <StackPanel HorizontalAlignment="Center">
                                    <Border Width="64" Height="64" CornerRadius="20" Margin="0,0,0,15" HorizontalAlignment="Center">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#4379EE" Offset="0"/>
                                                <GradientStop Color="#6B9BFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="&#xE710;" FontFamily="{StaticResource IconFont}" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                    </Border>
                                    <TextBlock Text="فاتورة جديدة" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- عميل جديد -->
                <Button Grid.Column="2" Click="QuickAddCustomer_Click" Cursor="Hand" Background="Transparent" BorderThickness="0" Padding="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Style="{StaticResource CardBorder}" Padding="14,22" Background="#FCFEFF">
                                <StackPanel HorizontalAlignment="Center">
                                    <Border Width="64" Height="64" CornerRadius="20" Background="#E8F5E9" Margin="0,0,0,15" HorizontalAlignment="Center">
                                        <TextBlock Text="&#xE77B;" FontFamily="{StaticResource IconFont}" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="عميل جديد" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- منتج جديد -->
                <Button Grid.Column="4" Click="QuickAddProduct_Click" Cursor="Hand" Background="Transparent" BorderThickness="0" Padding="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Style="{StaticResource CardBorder}" Padding="14,22" Background="#FCFEFF">
                                <StackPanel HorizontalAlignment="Center">
                                    <Border Width="64" Height="64" CornerRadius="20" Background="#FFF3E0" Margin="0,0,0,15" HorizontalAlignment="Center">
                                        <TextBlock Text="&#xE8EC;" FontFamily="{StaticResource IconFont}" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="منتج جديد" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- التقارير -->
                <Button Grid.Column="6" Click="QuickOpenReports_Click" Cursor="Hand" Background="Transparent" BorderThickness="0" Padding="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Style="{StaticResource CardBorder}" Padding="14,22" Background="#FCFEFF">
                                <StackPanel HorizontalAlignment="Center">
                                    <Border Width="64" Height="64" CornerRadius="20" Background="#FCE4EC" Margin="0,0,0,15" HorizontalAlignment="Center">
                                        <TextBlock Text="&#xE8A5;" FontFamily="{StaticResource IconFont}" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="التقارير" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- الإعدادات -->
                <Button Grid.Column="8" Click="QuickOpenSettings_Click" Cursor="Hand" Background="Transparent" BorderThickness="0" Padding="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Style="{StaticResource CardBorder}" Padding="14,22" Background="#FCFEFF">
                                <StackPanel HorizontalAlignment="Center">
                                    <Border Width="64" Height="64" CornerRadius="20" Background="#E3F2FD" Margin="0,0,0,15" HorizontalAlignment="Center">
                                        <TextBlock Text="&#xE713;" FontFamily="{StaticResource IconFont}" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="الإعدادات" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- ═══════════════════════════════════════════════════════════════════════════════ -->
            <!-- بطاقات الإحصائيات -->
            <!-- ═══════════════════════════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="2" Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- مبيعات اليوم -->
                <Border Grid.Column="0" Style="{StaticResource StatCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <Border Width="45" Height="45" CornerRadius="12" Margin="0,0,12,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#4379EE" Offset="0"/>
                                        <GradientStop Color="#6B9BFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="&#xE825;" FontFamily="{StaticResource IconFont}" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                            </Border>
                            <TextBlock Text="مبيعات اليوم" Style="{StaticResource BodyLabel}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="TodaySalesText" Grid.Row="1" Text="ر.ي. 0" Style="{StaticResource StatValueLabel}" Margin="0,15,0,5"/>
                        <TextBlock x:Name="TodaySalesCountText" Grid.Row="2" Text="0 فاتورة" Style="{StaticResource BodyLabel}"/>
                    </Grid>
                </Border>

                <!-- إجمالي الفواتير -->
                <Border Grid.Column="2" Style="{StaticResource StatCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <Border Width="45" Height="45" CornerRadius="12" Background="#FFF3E0" Margin="0,0,12,0">
                                <TextBlock Text="&#xE8A5;" FontFamily="{StaticResource IconFont}" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#F57C00"/>
                            </Border>
                            <TextBlock Text="الفواتير" Style="{StaticResource BodyLabel}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="TotalInvoicesText" Grid.Row="1" Text="0" Style="{StaticResource StatValueLabel}" Margin="0,15,0,5"/>
                        <TextBlock x:Name="MonthlyInvoicesText" Grid.Row="2" Text="0 هذا الشهر" Style="{StaticResource BodyLabel}"/>
                    </Grid>
                </Border>

                <!-- العملاء -->
                <Border Grid.Column="4" Style="{StaticResource StatCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <Border Width="45" Height="45" CornerRadius="12" Background="#E8F5E9" Margin="0,0,12,0">
                                <TextBlock Text="&#xE716;" FontFamily="{StaticResource IconFont}" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#388E3C"/>
                            </Border>
                            <TextBlock Text="العملاء" Style="{StaticResource BodyLabel}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="TotalCustomersText" Grid.Row="1" Text="0" Style="{StaticResource StatValueLabel}" Margin="0,15,0,5"/>
                        <TextBlock x:Name="NewCustomersText" Grid.Row="2" Text="+0 جديد" Style="{StaticResource BodyLabel}"/>
                    </Grid>
                </Border>

                <!-- المنتجات -->
                <Border Grid.Column="6" Style="{StaticResource StatCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <Border Width="45" Height="45" CornerRadius="12" Background="#FCE4EC" Margin="0,0,12,0">
                                <TextBlock Text="&#xE7B8;" FontFamily="{StaticResource IconFont}" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#C2185B"/>
                            </Border>
                            <TextBlock Text="المنتجات" Style="{StaticResource BodyLabel}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="TotalProductsText" Grid.Row="1" Text="0" Style="{StaticResource StatValueLabel}" Margin="0,15,0,5"/>
                        <TextBlock x:Name="LowStockCountText" Grid.Row="2" Text="0 منخفض" Style="{StaticResource BodyLabel}" Foreground="{StaticResource WarningBrush}"/>
                    </Grid>
                </Border>

            </Grid>

            <!-- ═══════════════════════════════════════════════════════════════════════════════ -->
            <!-- بطاقات إضافية -->
            <!-- ═══════════════════════════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="3" Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- إجمالي المبيعات الشهرية -->
                <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="إجمالي المبيعات (هذا الشهر)" Style="{StaticResource BodyLabel}"/>
                            <TextBlock x:Name="TotalSalesText" Text="ر.ي. 0" FontSize="30" FontWeight="Bold" Foreground="{StaticResource SecondaryBrush}" Margin="0,10,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="70" Height="70" CornerRadius="35" Background="{StaticResource SecondaryGradient}">
                            <TextBlock Text="&#xE9D9;" FontFamily="{StaticResource IconFont}" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- متوسط قيمة الفاتورة -->
                <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="متوسط قيمة الفاتورة" Style="{StaticResource BodyLabel}"/>
                            <TextBlock x:Name="AvgOrderValueText" Text="ر.ي. 0" FontSize="30" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,10,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="70" Height="70" CornerRadius="35" Background="{StaticResource PrimaryGradient}">
                            <TextBlock Text="&#xE9D2;" FontFamily="{StaticResource IconFont}" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- ═══════════════════════════════════════════════════════════════════════════════ -->
            <!-- الرسوم البيانية -->
            <!-- ═══════════════════════════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="4" Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- رسم المبيعات -->
                <Border Grid.Column="0" Style="{StaticResource CardBorder}" ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="المبيعات - آخر 7 أيام" Style="{StaticResource SubHeaderLabel}" Margin="0,0,0,25"/>
                        <ContentControl x:Name="SalesChartContainer" Grid.Row="1" Height="300" ClipToBounds="True"/>
                    </Grid>
                </Border>

                <!-- رسم الفئات -->
                <Border Grid.Column="2" Style="{StaticResource CardBorder}" ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="أفضل الفئات مبيعاً" Style="{StaticResource SubHeaderLabel}" Margin="0,0,0,25"/>
                        <ContentControl x:Name="CategoryChartContainer" Grid.Row="1" Height="300" ClipToBounds="True"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- ═══════════════════════════════════════════════════════════════════════════════ -->
            <!-- التنبيهات والنشاطات -->
            <!-- ═══════════════════════════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="5" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- التنبيهات -->
                <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                            <TextBlock Text="&#xE7BA;" FontFamily="{StaticResource IconFont}" FontSize="22" Foreground="{StaticResource WarningBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="التنبيهات" Style="{StaticResource SubHeaderLabel}"/>
                        </StackPanel>

                        <DataGrid x:Name="LowStockGrid" Grid.Row="1" Style="{StaticResource ModernDataGridStyle}" MaxHeight="350" Visibility="Collapsed">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="📌" Binding="{Binding Icon}" Width="50" IsReadOnly="True"/>
                                <DataGridTextColumn Header="المنتج" Binding="{Binding Name}" Width="1.5*" ElementStyle="{StaticResource DataGridTextColumnElementStyle}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="الحالة" Binding="{Binding Message}" Width="2*" ElementStyle="{StaticResource DataGridTextColumnElementStyle}" IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel x:Name="NoAlertsPanel" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,50,0,50">
                            <TextBlock Text="&#xE73E;" FontFamily="{StaticResource IconFont}" FontSize="50" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="لا توجد تنبيهات" FontSize="16" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- النشاطات الأخيرة -->
                <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                            <TextBlock Text="&#xE8C8;" FontFamily="{StaticResource IconFont}" FontSize="22" Margin="0,0,8,0"/>
                            <TextBlock Text="آخر النشاطات" Style="{StaticResource SubHeaderLabel}"/>
                        </StackPanel>

                        <DataGrid x:Name="ActivityLogGrid" Grid.Row="1" Style="{StaticResource ModernDataGridStyle}" MaxHeight="350" SelectionChanged="ActivityLogGrid_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="النشاط" Binding="{Binding Action}" Width="*" ElementStyle="{StaticResource DataGridTextColumnElementStyle}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="التفاصيل" Binding="{Binding Details}" Width="2*" ElementStyle="{StaticResource DataGridTextColumnElementStyle}" IsReadOnly="True"/>
                                <DataGridTextColumn Header="التاريخ" Binding="{Binding LogDateDisplay}" Width="*" ElementStyle="{StaticResource DataGridTextColumnElementStyle}" IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

        </Grid>
    </ScrollViewer>

</UserControl>


