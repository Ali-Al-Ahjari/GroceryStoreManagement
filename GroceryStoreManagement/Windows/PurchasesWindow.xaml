<UserControl x:Class="GroceryStoreManagement.Windows.PurchasesWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" FlowDirection="RightToLeft" Language="ar-YE" Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header & Stats -->
            <RowDefinition Height="Auto"/>
            <!-- Filters -->
            <RowDefinition Height="*"/>
            <!-- DataGrid -->
        </Grid.RowDefinitions>

        <!-- 1. Header & Stats Cards -->
        <Grid Grid.Row="0" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Title -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="إدارة المشتريات" Style="{StaticResource HeaderLabel}"/>
                <TextBlock Text="سجل فواتير الشراء من الموردين" Style="{StaticResource BodyLabel}" Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Stats Cards -->
            <Grid Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total Invoices -->
                <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="5,0" Padding="15">
                    <StackPanel>
                        <TextBlock Text="عدد الفواتير" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="TotalInvoicesText" Text="0" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Total Purchases -->
                <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="5,0" Padding="15">
                    <StackPanel>
                        <TextBlock Text="إجمالى المشتريات" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="TotalPurchasesText" Text="ر.ي 0" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource SecondaryBrush}" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Total Paid -->
                <Border Grid.Column="2" Style="{StaticResource CardBorder}" Margin="5,0" Padding="15">
                    <StackPanel>
                        <TextBlock Text="المدفوع" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="TotalPaidText" Text="ر.ي 0" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Total Remaining -->
                <Border Grid.Column="3" Style="{StaticResource CardBorder}" Margin="5,0" Padding="15">
                    <StackPanel>
                        <TextBlock Text="متبقي للموردين" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="TotalRemainingText" Text="ر.ي 0" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource ErrorBrush}" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- 2. Action Bar & Filters -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,20" Padding="15">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <Grid HorizontalAlignment="Left" MinWidth="980">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- New Purchase Button -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Search -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Filters -->
                    <ColumnDefinition Width="*"/>
                    <!-- Spacer -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Reset -->
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnNewPurchase" Grid.Column="0" Click="NewPurchase_Click" Style="{StaticResource PrimaryButton}" Margin="0,0,20,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="{StaticResource IconFont}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="فاتورة شراء جديدة" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Search -->
                <Grid Grid.Column="1" Margin="0,0,15,0" Width="220">
                    <TextBox x:Name="SearchTextBox" Style="{StaticResource ModernTextBox}" Padding="30,10,10,10" TextChanged="SearchTextBox_TextChanged"/>
                    <TextBlock Text="&#xE721;" FontFamily="{StaticResource IconFont}" FontSize="16" IsHitTestVisible="False" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" Foreground="{DynamicResource TextMutedBrush}"/>
                    <Button x:Name="ClearSearchButton" Click="ClearSearch_Click" Style="{StaticResource IconButton}" Visibility="Collapsed" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0" Width="20" Height="20">
                        <TextBlock Text="&#xE711;" FontFamily="{StaticResource IconFont}" FontSize="10" />
                    </Button>
                </Grid>

                <!-- Filters -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <DatePicker x:Name="DateFromPicker" Width="110" Margin="5,0" SelectedDateChanged="FilterChanged" VerticalAlignment="Center" FlowDirection="LeftToRight"/>
                    <TextBlock Text="إلى" VerticalAlignment="Center"/>
                    <DatePicker x:Name="DateToPicker" Width="110" Margin="5,0" SelectedDateChanged="FilterChanged" VerticalAlignment="Center" FlowDirection="LeftToRight"/>

                    <ComboBox x:Name="PaymentStatusComboBox" Width="110" Margin="10,0,0,0" Style="{StaticResource ModernComboBox}" SelectionChanged="FilterChanged">
                        <ComboBoxItem Content="الكل" IsSelected="True"/>
                        <ComboBoxItem Content="مدفوعة بالكامل"/>
                        <ComboBoxItem Content="مدفوعة جزئياً"/>
                        <ComboBoxItem Content="غير مدفوعة"/>
                    </ComboBox>
                </StackPanel>

                <!-- Reset -->
                <Button Grid.Column="4" Click="ResetFilters_Click" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" Padding="16,10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" FontFamily="{StaticResource IconFont}" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="إعادة تعيين" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                </Grid>
            </ScrollViewer>
        </Border>

        <!-- 3. DataGrid -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="0">
            <DataGrid x:Name="PurchasesGrid" Style="{StaticResource ModernDataGridStyle}" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="PurchasesGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding PurchaseID}" Width="60" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTextColumn Header="رقم فاتورة المورد" Binding="{Binding InvoiceNumber}" Width="100" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTextColumn Header="التاريخ" Binding="{Binding PurchaseDate, StringFormat=yyyy/MM/dd}" Width="100" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTextColumn Header="المورد" Binding="{Binding SupplierName}" Width="*" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTextColumn Header="عدد العناصر" Binding="{Binding ItemCount}" Width="80" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTextColumn Header="الإجمالي" Binding="{Binding TotalAmount, StringFormat='{}{0:#,##0.##}'}" Width="100" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTextColumn Header="المدفوع" Binding="{Binding PaidAmount, StringFormat='{}{0:#,##0.##}'}" Width="100" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTextColumn Header="المتبقي" Binding="{Binding RemainingAmount, StringFormat='{}{0:#,##0.##}'}" Width="100" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>

                    <DataGridTemplateColumn Header="الحالة" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding PaymentStatusColor}" CornerRadius="5" Padding="5,2" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding PaymentStatusArabic}" Foreground="White" FontSize="11"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="الإجراءات" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button ToolTip="استيراد للمخزون" Click="ImportToInventory_Click" Tag="{Binding PurchaseID}" Style="{StaticResource IconButton}" Margin="2">
                                        <TextBlock Text="&#xE8B5;" FontFamily="{StaticResource IconFont}" FontSize="14"/>
                                    </Button>
                                    <Button ToolTip="تعديل" Click="EditPurchase_Click" Tag="{Binding PurchaseID}" Style="{StaticResource IconButton}" Margin="2">
                                        <TextBlock Text="&#xE70F;" FontFamily="{StaticResource IconFont}" FontSize="14"/>
                                    </Button>
                                    <Button ToolTip="سداد" Click="PaySupplier_Click" Tag="{Binding PurchaseID}" Style="{StaticResource IconButton}" Margin="2">
                                        <TextBlock Text="&#xE8A5;" FontFamily="{StaticResource IconFont}" FontSize="14"/>
                                    </Button>
                                    <Button ToolTip="حذف" Click="DeletePurchase_Click" Tag="{Binding PurchaseID}" Style="{StaticResource IconButton}" Foreground="{DynamicResource DangerBrush}" Margin="2">
                                        <TextBlock Text="&#xE74D;" FontFamily="{StaticResource IconFont}" FontSize="14"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

    </Grid>
</UserControl>



