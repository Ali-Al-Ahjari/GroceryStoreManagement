<Window x:Class="GroceryStoreManagement.Windows.ShiftManagementWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="إدارة الوردية" Height="620" Width="520" WindowStartupLocation="CenterOwner" WindowStyle="None" AllowsTransparency="True" Background="Transparent" ResizeMode="NoResize" FlowDirection="RightToLeft" Language="ar-YE" ShowInTaskbar="False" MaxHeight="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Height}" MaxWidth="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Width}">

    <Border CornerRadius="16" Background="{StaticResource SurfaceBrush}" Effect="{StaticResource CardShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PrimaryGradient}" CornerRadius="16,16,0,0" Padding="20,15" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="إدارة الوردية" FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <Button Click="CloseButton_Click" Style="{StaticResource IconButton}" Foreground="White" HorizontalAlignment="Left">
                        <TextBlock Text="&#xE711;" FontFamily="{StaticResource IconFont}" />
                    </Button>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" Padding="24,20" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Background="{StaticResource BackgroundBrush}" CornerRadius="10" Padding="14" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="حالة الوردية الحالية" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="ShiftStateText" Text="-" FontSize="16" FontWeight="Bold" Margin="0,8,0,0"/>
                            <TextBlock x:Name="ShiftInfoText" Text="" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="StartShiftPanel" Background="{StaticResource BackgroundBrush}" CornerRadius="10" Padding="14" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="بدء وردية جديدة" Style="{StaticResource SubHeaderLabel}" Margin="0,0,0,10"/>
                            <TextBlock Text="العهدة الافتتاحية" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="OpeningCashTextBox" Style="{StaticResource ModernTextBox}" Text="0" FlowDirection="LeftToRight" TextAlignment="Center"/>
                            <TextBlock Text="ملاحظات (اختياري)" Style="{StaticResource LabelStyle}" Margin="0,8,0,4"/>
                            <TextBox x:Name="StartNotesTextBox" Style="{StaticResource ModernTextBox}" Height="60" AcceptsReturn="True" TextWrapping="Wrap"/>
                            <Button Click="StartShift_Click" Style="{StaticResource PrimaryButton}" Margin="0,15,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE7C3;" FontFamily="{StaticResource IconFont}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                                    <TextBlock Text="بدء الوردية" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border x:Name="CloseShiftPanel" Background="{StaticResource BackgroundBrush}" CornerRadius="10" Padding="14" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="إغلاق الوردية" Style="{StaticResource SubHeaderLabel}" Margin="0,0,0,10"/>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="المتوقع في الدرج:" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="ExpectedCashText" Grid.Column="1" FontWeight="Bold"/>
                            </Grid>

                            <TextBlock Text="النقدية الفعلية في الدرج" Style="{StaticResource LabelStyle}"/>
                            <TextBox x:Name="ClosingCashTextBox" Style="{StaticResource ModernTextBox}" Text="0" FlowDirection="LeftToRight" TextAlignment="Center"/>

                            <TextBlock Text="ملاحظات الإغلاق (اختياري)" Style="{StaticResource LabelStyle}" Margin="0,8,0,4"/>
                            <TextBox x:Name="CloseNotesTextBox" Style="{StaticResource ModernTextBox}" Height="60" AcceptsReturn="True" TextWrapping="Wrap"/>

                            <Button Click="CloseShift_Click" Style="{StaticResource SecondaryButton}" Margin="0,15,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE749;" FontFamily="{StaticResource IconFont}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                                    <TextBlock Text="إغلاق الوردية وطباعة Z-Report" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,1,0,0" Padding="20,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" FlowDirection="LeftToRight">
                    <Button Click="CloseButton_Click" Style="{StaticResource OutlineButton}" Padding="20,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE711;" FontFamily="{StaticResource IconFont}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Text="إغلاق" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
