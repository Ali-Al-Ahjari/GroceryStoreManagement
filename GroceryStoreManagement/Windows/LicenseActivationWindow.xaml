<Window x:Class="GroceryStoreManagement.Windows.LicenseActivationWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="تفعيل الترخيص" Height="760" Width="940" MinHeight="680" MinWidth="820" MaxHeight="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Height}" MaxWidth="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Width}" WindowStartupLocation="CenterOwner" ResizeMode="CanResize" FlowDirection="RightToLeft" Language="ar-YE" Background="#EAF2F6" FontFamily="{StaticResource PrimaryFont}">

    <Window.Resources>
        <Style x:Key="LicensePanelCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D6E2E9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="14"/>
        </Style>

        <Style x:Key="SmallOutlineButton" TargetType="Button" BasedOn="{StaticResource OutlineButton}">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinHeight" Value="34"/>
        </Style>

        <Style x:Key="SmallPrimaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinHeight" Value="38"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#EAF2F6" Offset="0"/>
                <GradientStop Color="#DCEBF2" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Canvas IsHitTestVisible="False">
            <Ellipse Width="300" Height="300" Fill="#20FFFFFF" Canvas.Top="-90" Canvas.Right="-80"/>
            <Ellipse Width="220" Height="220" Fill="#25FFFFFF" Canvas.Left="-50" Canvas.Bottom="-70"/>
        </Canvas>

        <Border CornerRadius="24" Background="#F8FBFD" BorderBrush="#D8E4EA" BorderThickness="1" Padding="24">
            <Border.Effect>
                <DropShadowEffect BlurRadius="36" ShadowDepth="10" Direction="270" Opacity="0.23" Color="#0B1720"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource LicensePanelCard}" Background="#F0F9FF" BorderBrush="#C3DEEF">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="58" Height="58" CornerRadius="18" Background="#D9F2F8" VerticalAlignment="Center">
                            <TextBlock Text="&#xE8D7;" FontFamily="{StaticResource IconFont}" FontSize="26" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#0F766E"/>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="14,0,14,0" VerticalAlignment="Center">
                            <TextBlock Text="تفعيل وتجديد الترخيص" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
                            <TextBlock Text="أرسل بصمة الجهاز للمطور، ثم ألصق كود التفعيل الذي يصلك." Margin="0,6,0,0" FontSize="13" Foreground="#475569"/>
                        </StackPanel>

                        <Border Grid.Column="2" Background="#FFFFFF" CornerRadius="10" BorderBrush="#BFDBFE" BorderThickness="1" Padding="10,8" VerticalAlignment="Center" MinWidth="190">
                            <StackPanel>
                                <TextBlock Text="الحالة الحالية" FontSize="11" Foreground="#1E40AF" FontWeight="SemiBold"/>
                                <TextBlock x:Name="TxtCurrentLicenseState" Margin="0,3,0,0" FontSize="13" FontWeight="Bold" Foreground="#1E40AF"/>
                                <TextBlock x:Name="TxtCurrentLicenseExpiry" Margin="0,2,0,0" FontSize="11" Foreground="#334155" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Margin="0,14,0,0" Style="{StaticResource LicensePanelCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="بصمة هذا الجهاز" FontSize="12" FontWeight="Bold" Foreground="#0F766E"/>
                            <TextBox x:Name="TxtMachineFingerprint" Margin="0,8,0,0" IsReadOnly="True" FontFamily="Consolas" FontSize="12" TextAlignment="Left" FlowDirection="LeftToRight" HorizontalContentAlignment="Left" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <Button x:Name="BtnCopyFingerprint" Width="132" Margin="0,0,0,6" Click="BtnCopyFingerprint_Click" Style="{StaticResource SmallOutlineButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8C8;" FontFamily="{StaticResource IconFont}" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="نسخ البصمة" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnCopyActivationRequest" Width="132" Click="BtnCopyActivationRequest_Click" Style="{StaticResource SmallOutlineButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8C8;" FontFamily="{StaticResource IconFont}" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="نسخ رسالة" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <TextBlock Text="أرسلها للمطور" Margin="0,6,0,0" FontSize="11" Foreground="#64748B" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="2" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource LicensePanelCard}" Margin="0,0,7,0">
                        <StackPanel>
                            <TextBlock Text="خطوات سريعة" FontSize="13" FontWeight="Bold" Foreground="#0F172A"/>
                            <TextBlock Text="1. اضغط نسخ رسالة وأرسلها للمطور." Margin="0,9,0,0" Foreground="#475569" FontSize="12"/>
                            <TextBlock Text="2. استلم رسالة الرد التي فيها كود التفعيل." Margin="0,4,0,0" Foreground="#475569" FontSize="12"/>
                            <TextBlock Text="3. الصق الكود واضغط تفعيل." Margin="0,4,0,0" Foreground="#475569" FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource LicensePanelCard}" Margin="7,0,0,0" Background="#FFF7ED" BorderBrush="#FED7AA">
                        <StackPanel>
                            <TextBlock Text="ملاحظة أمان" FontSize="13" FontWeight="Bold" Foreground="#9A3412"/>
                            <TextBlock Text="الكود مرتبط ببصمة هذا الجهاز فقط." Margin="0,8,0,0" Foreground="#7C2D12" FontSize="12"/>
                            <TextBlock Text="لا يمكن استخدام نفس الكود على جهاز آخر." Margin="0,4,0,0" Foreground="#7C2D12" FontSize="12"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="3" Margin="0,14,0,0" Style="{StaticResource LicensePanelCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="كود التفعيل" FontSize="13" FontWeight="Bold" Foreground="#0F172A"/>
                                <TextBlock Text="يمكن لصق الكود كما هو حتى لو كان على أكثر من سطر." Margin="0,4,0,0" Foreground="#64748B" FontSize="11"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" FlowDirection="LeftToRight">
                                <Button x:Name="BtnPasteActivationCode" Width="88" Margin="0,0,8,0" Style="{StaticResource SmallOutlineButton}" Click="BtnPasteActivationCode_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8C8;" FontFamily="{StaticResource IconFont}" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="لصق" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="BtnClearActivationCode" Width="88" Style="{StaticResource SmallOutlineButton}" Click="BtnClearActivationCode_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE74D;" FontFamily="{StaticResource IconFont}" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="مسح" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <TextBox x:Name="TxtActivationCode" Grid.Row="1" Margin="0,12,0,12" MinHeight="160" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12" TextAlignment="Left" FlowDirection="LeftToRight" HorizontalContentAlignment="Left" VerticalContentAlignment="Top" TextChanged="TxtActivationCode_TextChanged" PreviewKeyDown="TxtActivationCode_PreviewKeyDown"/>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="اختصار لوحة المفاتيح: Ctrl+Enter لتنفيذ التفعيل." FontSize="11" Foreground="#64748B"/>

                            <TextBlock x:Name="TxtCodeStats" Grid.Column="1" FontSize="11" Foreground="#64748B"/>
                        </Grid>
                    </Grid>
                </Border>

                <Grid Grid.Row="4" Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border x:Name="StatusBanner" Grid.Row="0" CornerRadius="12" BorderThickness="1" BorderBrush="#BFDBFE" Background="#EFF6FF" Padding="12">
                        <StackPanel>
                            <TextBlock x:Name="TxtStatusTitle" Text="جاهز" FontSize="12" FontWeight="Bold" Foreground="#1E40AF"/>
                            <TextBlock x:Name="TxtStatusMessage" Text="أدخل كود التفعيل ثم اضغط تفعيل الآن." Margin="0,4,0,0" FontSize="12" Foreground="#334155" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" FlowDirection="LeftToRight" Margin="0,14,0,0">
                        <Button x:Name="BtnCancel" Width="116" Margin="0,0,10,0" IsCancel="True" Style="{StaticResource SmallOutlineButton}" Click="BtnCancel_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE711;" FontFamily="{StaticResource IconFont}" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="إلغاء" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="BtnActivate" Width="170" IsDefault="True" Style="{StaticResource SmallPrimaryButton}" Click="BtnActivate_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE73E;" FontFamily="{StaticResource IconFont}" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtActivateButtonLabel" Text="تفعيل الآن" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
