<Window x:Class="GroceryStoreManagement.Windows.ReturnDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="إرجاع منتجات" Height="620" Width="700" WindowStartupLocation="CenterOwner" WindowStyle="None" AllowsTransparency="True" Background="Transparent" ResizeMode="NoResize" FlowDirection="RightToLeft" Language="ar-YE" ShowInTaskbar="False" MaxHeight="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Height}" MaxWidth="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Width}">

    <Border CornerRadius="16" Background="{DynamicResource SurfaceBrush}" Effect="{DynamicResource CardShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource WarningGradient}" CornerRadius="16,16,0,0" Padding="20,15">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7A7;" FontFamily="{StaticResource IconFont}" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="White"/>
                        <TextBlock Text="إرجاع منتجات" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Click="CloseButton_Click" Style="{StaticResource IconButton}" Foreground="White" HorizontalAlignment="Left" Margin="620,0,0,0">
                        <TextBlock Text="&#xE711;" FontFamily="{StaticResource IconFont}" />
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Invoice Info -->
                <TextBlock x:Name="InvoiceInfoText" Text="فاتورة #0" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                <!-- Items Grid -->
                <DataGrid Grid.Row="1" x:Name="ReturnItemsGrid" Style="{StaticResource ModernDataGridStyle}" AutoGenerateColumns="False" CanUserAddRows="False" Margin="0,0,0,15">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="المنتج" Binding="{Binding ProductName}" Width="Auto" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                        <DataGridTextColumn Header="العدد الكلي" Binding="{Binding Quantity}" Width="Auto" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                        <DataGridTextColumn Header="تم إرجاعه" Binding="{Binding ReturnedQuantity}" Width="Auto" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                        <DataGridTextColumn Header="سعر الوحدة" Binding="{Binding DisplayUnitPrice}" Width="Auto" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>

                        <!-- Col for return qty input -->
                        <DataGridTemplateColumn Header="الكمية للإرجاع" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding QtyToReturn, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Padding="5" TextAlignment="Center" PreviewTextInput="QtyTextBox_PreviewTextInput"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="قيمة الاسترجاع" Binding="{Binding RefundAmount, StringFormat='{}{0:#,##0.##}'}" Width="120" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Footer / Totals -->
                <StackPanel Grid.Row="2">
                    <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="5" Padding="15" Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="إجمالي الاسترجاع:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0" Width="91"/>
                            <TextBlock x:Name="TotalRefundText" Text="0.00 ر.ي." FontSize="18" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="سبب الإرجاع" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="ReturnReasonTextBox" Style="{StaticResource ModernTextBox}" Height="60" AcceptsReturn="True" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>

            <!-- Actions -->
            <Border Grid.Row="2" BorderBrush="{DynamicResource BorderLightBrush}" BorderThickness="0,1,0,0" Padding="20,15">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" FlowDirection="LeftToRight">
                    <Button Click="CloseButton_Click" Style="{StaticResource OutlineButton}" Padding="25,12" Margin="10,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE711;" FontFamily="{StaticResource IconFont}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Text="إلغاء" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Click="ConfirmReturn_Click" Style="{StaticResource PrimaryButton}" Background="{DynamicResource WarningBrush}" BorderBrush="{DynamicResource WarningBrush}" Padding="25,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE73E;" FontFamily="{StaticResource IconFont}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Text="تأكيد الإرجاع" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>

</Window>



