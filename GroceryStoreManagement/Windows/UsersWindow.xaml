<UserControl x:Class="GroceryStoreManagement.Windows.UsersWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" FlowDirection="RightToLeft" Language="ar-YE" Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- العنوان -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="إدارة المستخدمين" Style="{StaticResource HeaderLabel}"/>
                <TextBlock Text="إدارة حسابات المستخدمين والصلاحيات" Style="{StaticResource BodyLabel}" Margin="0,5,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="BtnManageRoles" Style="{StaticResource OutlineButton}" Padding="15,10" Margin="0,0,10,0" FontSize="12" Click="BtnManageRoles_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE716;" FontFamily="{StaticResource IconFont}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="إدارة الأدوار" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button x:Name="BtnAddUser" Style="{StaticResource PrimaryButton}" Padding="15,10" FontSize="12" Click="BtnAddUser_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="{StaticResource IconFont}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="إضافة مستخدم" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- البحث -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,20" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{DynamicResource BackgroundBrush}" CornerRadius="8">
                    <TextBox x:Name="TxtSearch" Style="{StaticResource ModernTextBox}" Background="Transparent" Padding="40,12,12,12" TextChanged="TxtSearch_TextChanged"/>
                </Border>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="15,0,0,0">
                    <TextBlock Text="الدور:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="CmbRole" Width="150" Style="{StaticResource ModernComboBox}" DisplayMemberPath="RoleName" SelectedValuePath="RoleID" SelectionChanged="CmbRole_SelectionChanged"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- جدول المستخدمين -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="0">
            <DataGrid x:Name="UsersDataGrid" Style="{StaticResource ModernDataGridStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding UserID}" Width="70" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTextColumn Header="اسم المستخدم" Binding="{Binding Username}" Width="140" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTextColumn Header="الاسم الكامل" Binding="{Binding FullName}" Width="*" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTextColumn Header="البريد" Binding="{Binding Email}" Width="180" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTextColumn Header="الهاتف" Binding="{Binding Phone}" Width="120" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTextColumn Header="الدور" Binding="{Binding RoleName}" Width="130" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTemplateColumn Header="الحالة" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Padding="8,4" HorizontalAlignment="Center" Background="{Binding StatusColor}">
                                    <TextBlock Text="{Binding StatusArabic}" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="آخر دخول" Binding="{Binding LastLoginDisplay}" Width="120" ElementStyle="{StaticResource DataGridTextColumnElementStyle}"/>
                    <DataGridTemplateColumn Header="الإجراءات" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Style="{StaticResource IconButton}" Width="32" Height="32" FontSize="14" ToolTip="الصلاحيات" Tag="{Binding UserID}" Click="BtnPermissions_Click">
                                        <TextBlock Text="&#xE8D7;" FontFamily="{StaticResource IconFont}"/>
                                    </Button>
                                    <Button Style="{StaticResource IconButton}" Width="32" Height="32" FontSize="14" ToolTip="تعديل" Tag="{Binding UserID}" Click="BtnEditUser_Click">
                                        <TextBlock Text="&#xE70F;" FontFamily="{StaticResource IconFont}"/>
                                    </Button>
                                    <Button Style="{StaticResource IconButton}" Width="32" Height="32" FontSize="14" ToolTip="تغيير الحالة" Tag="{Binding UserID}" Click="BtnToggleStatus_Click">
                                        <TextBlock Text="&#xE72E;" FontFamily="{StaticResource IconFont}"/>
                                    </Button>
                                    <Button Style="{StaticResource IconButton}" Width="32" Height="32" FontSize="14" Foreground="{DynamicResource ErrorBrush}" ToolTip="حذف" Tag="{Binding UserID}" Click="BtnDeleteUser_Click">
                                        <TextBlock Text="&#xE74D;" FontFamily="{StaticResource IconFont}"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- شريط الحالة -->
        <TextBlock Grid.Row="3" x:Name="TxtTotalUsers" Text="إجمالي المستخدمين: 0" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,15,0,0"/>

    </Grid>

</UserControl>
