<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════════════════════ -->
    <!-- Dark Theme Colors (Deep Charcoal Slate & Soft Sky Blue) -->
    <!-- ═══════════════════════════════════════════════════════════════════════════════ -->

    <!-- Accent (Sky Blue) Colors -->
    <Color x:Key="ColorAccentPrimary">#4791BF</Color>
    <Color x:Key="ColorAccentLight">#5FAAD8</Color>
    <Color x:Key="ColorAccentDark">#3078A6</Color>
    <Color x:Key="ColorAccentMuted">#1A2B35</Color> <!-- 10% opacity blue-ish accent -->

    <!-- Neutral (Charcoal Slate) Colors -->
    <Color x:Key="ColorBackgroundMain">#1E1F22</Color>
    <Color x:Key="ColorBackgroundHeader">#1E1F22</Color>
    <Color x:Key="ColorSurfaceCore">#2A2B2F</Color>
    <Color x:Key="ColorSidebarBackground">#1E1F22</Color>
    <Color x:Key="ColorSidebarHover">#2A2B2F</Color>

    <!-- Text Colors -->
    <Color x:Key="ColorTextPrimary">#F8FAFC</Color>
    <Color x:Key="ColorTextSecondary">#CBD5E1</Color>
    <Color x:Key="ColorTextMuted">#64748B</Color>
    <Color x:Key="ColorTextLight">#F8FAFC</Color>

    <!-- Border Colors (Soft Alpha Borders) -->
    <Color x:Key="ColorBorderDefault">#1AFFFFFF</Color> <!-- 10% white border -->
    <Color x:Key="ColorBorderLight">#0DFFFFFF</Color>   <!-- 5% white border -->

    <!-- Semantic States Colors -->
    <Color x:Key="ColorSuccess">#10B981</Color>
    <Color x:Key="ColorSuccessMuted">#064E3B</Color>
    <Color x:Key="ColorWarning">#F59E0B</Color>
    <Color x:Key="ColorWarningMuted">#78350F</Color>
    <Color x:Key="ColorError">#EF4444</Color>
    <Color x:Key="ColorErrorMuted">#7F1D1D</Color>
    <Color x:Key="ColorInfo">#4791BF</Color>
    <Color x:Key="ColorInfoMuted">#1A2B35</Color>

    <!-- ═══════════════════════════════════════════════════════════════════════════════ -->
    <!-- Dark Theme Solid Color Brushes -->
    <!-- ═══════════════════════════════════════════════════════════════════════════════ -->

    <SolidColorBrush x:Key="BrushAccentPrimary" Color="{StaticResource ColorAccentPrimary}"/>
    <SolidColorBrush x:Key="BrushAccentLight" Color="{StaticResource ColorAccentLight}"/>
    <SolidColorBrush x:Key="BrushAccentDark" Color="{StaticResource ColorAccentDark}"/>
    <SolidColorBrush x:Key="BrushAccentMuted" Color="{StaticResource ColorAccentMuted}"/>
    <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource ColorAccentPrimary}"/>

    <SolidColorBrush x:Key="BrushBackgroundMain" Color="{StaticResource ColorBackgroundMain}"/>
    <SolidColorBrush x:Key="BrushBackgroundHeader" Color="{StaticResource ColorBackgroundHeader}"/>
    <SolidColorBrush x:Key="BrushSurfaceCore" Color="{StaticResource ColorSurfaceCore}"/>
    <SolidColorBrush x:Key="BrushSidebarBackground" Color="{StaticResource ColorSidebarBackground}"/>
    <SolidColorBrush x:Key="BrushSidebarHover" Color="{StaticResource ColorSidebarHover}"/>

    <SolidColorBrush x:Key="BrushTextPrimary" Color="{StaticResource ColorTextPrimary}"/>
    <SolidColorBrush x:Key="BrushTextSecondary" Color="{StaticResource ColorTextSecondary}"/>
    <SolidColorBrush x:Key="BrushTextMuted" Color="{StaticResource ColorTextMuted}"/>
    <SolidColorBrush x:Key="BrushTextLight" Color="{StaticResource ColorTextLight}"/>

    <SolidColorBrush x:Key="BrushBorderDefault" Color="{StaticResource ColorBorderDefault}"/>
    <SolidColorBrush x:Key="BrushBorderLight" Color="{StaticResource ColorBorderLight}"/>

    <SolidColorBrush x:Key="BrushSuccess" Color="{StaticResource ColorSuccess}"/>
    <SolidColorBrush x:Key="BrushSuccessMuted" Color="{StaticResource ColorSuccessMuted}"/>
    <SolidColorBrush x:Key="BrushWarning" Color="{StaticResource ColorWarning}"/>
    <SolidColorBrush x:Key="BrushWarningMuted" Color="{StaticResource ColorWarningMuted}"/>
    <SolidColorBrush x:Key="BrushError" Color="{StaticResource ColorError}"/>
    <SolidColorBrush x:Key="BrushErrorMuted" Color="{StaticResource ColorErrorMuted}"/>
    <SolidColorBrush x:Key="BrushInfo" Color="{StaticResource ColorInfo}"/>
    <SolidColorBrush x:Key="BrushInfoMuted" Color="{StaticResource ColorInfoMuted}"/>

    <!-- Mapped Semantic Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource ColorAccentPrimary}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource ColorAccentLight}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource ColorAccentDark}"/>

    <SolidColorBrush x:Key="SecondaryBrush" Color="#B85DFF"/> <!-- Violet accent -->
    <SolidColorBrush x:Key="SecondaryDarkBrush" Color="#8B24E0"/>
    <SolidColorBrush x:Key="SecondaryLightBrush" Color="#1F132E"/>

    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource ColorBackgroundMain}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource ColorSurfaceCore}"/>
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource ColorSidebarBackground}"/>
    <SolidColorBrush x:Key="SidebarLightBrush" Color="{StaticResource ColorSidebarHover}"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="{StaticResource ColorSidebarHover}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource ColorTextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource ColorTextSecondary}"/>
    <SolidColorBrush x:Key="TextLightBrush" Color="{StaticResource ColorTextLight}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource ColorTextMuted}"/>

    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource ColorBorderDefault}"/>
    <SolidColorBrush x:Key="BorderLightBrush" Color="{StaticResource ColorBorderLight}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ColorError}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource ColorError}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource ColorSuccess}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource ColorWarning}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource ColorInfo}"/>
    <SolidColorBrush x:Key="SuccessBrushMuted" Color="{StaticResource ColorSuccessMuted}"/>
    <SolidColorBrush x:Key="WarningBrushMuted" Color="{StaticResource ColorWarningMuted}"/>
    <SolidColorBrush x:Key="ErrorBrushMuted" Color="{StaticResource ColorErrorMuted}"/>
    <SolidColorBrush x:Key="InfoBrushMuted" Color="{StaticResource ColorInfoMuted}"/>

    <!-- Input State Brushes -->
    <SolidColorBrush x:Key="BrushInputHover" Color="{StaticResource ColorAccentLight}"/>
    <SolidColorBrush x:Key="BrushInputFocusBg" Color="#1E2A35"/>
    <SolidColorBrush x:Key="BrushDisabledBackground" Color="#222326"/>
    <SolidColorBrush x:Key="BrushDisabledBorder" Color="#2D2F34"/>
    <SolidColorBrush x:Key="BrushDisabledText" Color="#4E5158"/>

    <!-- DataGrid Colors -->
    <Color x:Key="ColorDataGridHeader">#1E1F22</Color>
    <SolidColorBrush x:Key="BrushDataGridHeader" Color="{StaticResource ColorDataGridHeader}"/>
    
    <Color x:Key="ColorDataGridSelected">#3078A6</Color>
    <SolidColorBrush x:Key="BrushDataGridSelected" Color="{StaticResource ColorDataGridSelected}"/>
    
    <Color x:Key="ColorDataGridGridLines">#1AFFFFFF</Color>
    <SolidColorBrush x:Key="BrushDataGridGridLines" Color="{StaticResource ColorDataGridGridLines}"/>
    
    <Color x:Key="ColorDataGridAlternatingRow">#242529</Color>
    <SolidColorBrush x:Key="BrushDataGridAlternatingRow" Color="{StaticResource ColorDataGridAlternatingRow}"/>

    <!-- ═══════════════════════════════════════════════════════════════════════════════ -->
    <!-- Gradients -->
    <!-- ═══════════════════════════════════════════════════════════════════════════════ -->

    <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource ColorAccentPrimary}" Offset="0"/>
        <GradientStop Color="{StaticResource ColorAccentLight}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SidebarGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource ColorSidebarBackground}" Offset="0"/>
        <GradientStop Color="#161719" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SecondaryGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#B85DFF" Offset="0"/>
        <GradientStop Color="#8B24E0" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SuccessGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource ColorSuccess}" Offset="0"/>
        <GradientStop Color="#34D399" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="WarningGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource ColorWarning}" Offset="0"/>
        <GradientStop Color="#FBBF24" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="GlassGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1AFFFFFF" Offset="0"/>
        <GradientStop Color="#08FFFFFF" Offset="1"/>
    </LinearGradientBrush>

    <!-- ═══════════════════════════════════════════════════════════════════════════════ -->
    <!-- Shadow & Glow Effects -->
    <!-- ═══════════════════════════════════════════════════════════════════════════════ -->

    <DropShadowEffect x:Key="ElevationShadowLow" BlurRadius="12" ShadowDepth="2" Direction="270" Opacity="0.35" Color="#000000"/>
    <DropShadowEffect x:Key="ElevationShadowMedium" BlurRadius="24" ShadowDepth="6" Direction="270" Opacity="0.45" Color="#000000"/>
    <DropShadowEffect x:Key="ElevationShadowHigh" BlurRadius="36" ShadowDepth="12" Direction="270" Opacity="0.6" Color="#000000"/>
    <DropShadowEffect x:Key="AccentShadow" BlurRadius="16" ShadowDepth="4" Direction="270" Opacity="0.4" Color="{StaticResource ColorAccentPrimary}"/>
    <DropShadowEffect x:Key="ErrorGlowEffect" BlurRadius="8" ShadowDepth="0" Direction="0" Opacity="0.4" Color="{StaticResource ColorError}"/>
    <DropShadowEffect x:Key="DangerButtonShadow" BlurRadius="16" ShadowDepth="5" Direction="270" Opacity="0.4" Color="{StaticResource ColorError}"/>
    <DropShadowEffect x:Key="CardShadow" BlurRadius="24" ShadowDepth="6" Direction="270" Opacity="0.3" Color="#000000"/>
    <DropShadowEffect x:Key="CardShadowHover" BlurRadius="34" ShadowDepth="12" Direction="270" Opacity="0.3" Color="{StaticResource ColorAccentPrimary}"/>
    <DropShadowEffect x:Key="ButtonShadow" BlurRadius="16" ShadowDepth="5" Direction="270" Opacity="0.35" Color="{StaticResource ColorAccentPrimary}"/>
    <DropShadowEffect x:Key="DropdownShadow" BlurRadius="24" ShadowDepth="8" Direction="270" Opacity="0.45" Color="#000000"/>
    <DropShadowEffect x:Key="InputFocusGlow" BlurRadius="12" ShadowDepth="0" Direction="0" Opacity="0.3" Color="{StaticResource ColorAccentPrimary}"/>
    <DropShadowEffect x:Key="GlowEffect" BlurRadius="18" ShadowDepth="0" Direction="0" Opacity="0.4" Color="{StaticResource ColorSuccess}"/>
    <DropShadowEffect x:Key="DefaultShadow" BlurRadius="18" ShadowDepth="3" Direction="270" Opacity="0.3" Color="#000000"/>

</ResourceDictionary>
