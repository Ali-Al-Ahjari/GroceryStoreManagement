<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

    xmlns:sys="clr-namespace:System;assembly=mscorlib">



    <!--

    ═══════════════════════════════════════════════════════════════════════════════

    Styles.xaml - تصميم عصري وأنيق

    Modern & Elegant Design System

    ═══════════════════════════════════════════════════════════════════════════════

    -->



    <!-- Typography Tokens -->

    <FontFamily x:Key="FontFamilyPrimary">Segoe UI, Noto Sans Arabic, Tahoma, Arial</FontFamily>

    <FontFamily x:Key="FontFamilyIcons">Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol</FontFamily>

    

    <!-- Backward compatibility aliases -->

    <FontFamily x:Key="PrimaryFont">Segoe UI, Noto Sans Arabic, Tahoma, Arial</FontFamily>

    <FontFamily x:Key="IconFont">Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI Symbol</FontFamily>



    <sys:Double x:Key="FontSizeTitleLarge">32</sys:Double>

    <sys:Double x:Key="FontSizeHeader">24</sys:Double>

    <sys:Double x:Key="FontSizeSubHeader">18</sys:Double>

    <sys:Double x:Key="FontSizeBody">14</sys:Double>

    <sys:Double x:Key="FontSizeCaption">12</sys:Double>



    <FontWeight x:Key="FontWeightBold">Bold</FontWeight>

    <FontWeight x:Key="FontWeightSemiBold">SemiBold</FontWeight>

    <FontWeight x:Key="FontWeightRegular">Normal</FontWeight>



    <Style TargetType="Window">

        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>

        <Setter Property="SnapsToDevicePixels" Value="True"/>

        <Setter Property="UseLayoutRounding" Value="True"/>

        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>

        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>

    </Style>



    <Style TargetType="UserControl">

        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>

        <Setter Property="SnapsToDevicePixels" Value="True"/>

        <Setter Property="UseLayoutRounding" Value="True"/>

        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>

        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>

    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════════════════ -->

    <!-- لوحة الألوان وتصميم الرموز (Color Palette & Design Tokens) -->

    <!-- ═══════════════════════════════════════════════════════════════════════════════ -->



    <!-- Accent (Teal) Colors -->

    <Color x:Key="ColorAccentPrimary">#0F766E</Color>

    <Color x:Key="ColorAccentLight">#14B8A6</Color>

    <Color x:Key="ColorAccentDark">#115E59</Color>

    <Color x:Key="ColorAccentMuted">#EEF8F7</Color>



    <!-- Neutral (Slate) Colors -->

    <Color x:Key="ColorBackgroundMain">#F1F5F9</Color>

    <Color x:Key="ColorBackgroundHeader">#F8FAFC</Color>

    <Color x:Key="ColorSurfaceCore">#FFFFFF</Color>

    <Color x:Key="ColorSidebarBackground">#0F172A</Color>

    <Color x:Key="ColorSidebarHover">#1E293B</Color>



    <!-- Text Colors -->

    <Color x:Key="ColorTextPrimary">#0F172A</Color>

    <Color x:Key="ColorTextSecondary">#475569</Color>

    <Color x:Key="ColorTextMuted">#94A3B8</Color>

    <Color x:Key="ColorTextLight">#F8FAFC</Color>



    <!-- Border Colors -->

    <Color x:Key="ColorBorderDefault">#E2E8F0</Color>

    <Color x:Key="ColorBorderLight">#F1F5F9</Color>



    <!-- Semantic States Colors -->

    <Color x:Key="ColorSuccess">#16A34A</Color>

    <Color x:Key="ColorSuccessMuted">#E8F5E9</Color>

    <Color x:Key="ColorWarning">#D97706</Color>

    <Color x:Key="ColorWarningMuted">#FFF3E0</Color>

    <Color x:Key="ColorError">#DC2626</Color>

    <Color x:Key="ColorErrorMuted">#FFEBEE</Color>

    <Color x:Key="ColorInfo">#0EA5E9</Color>

    <Color x:Key="ColorInfoMuted">#E3F2FD</Color>



    <!-- Backward Compatibility Colors -->

    <Color x:Key="PrimaryColor">#0F766E</Color>

    <Color x:Key="PrimaryLightColor">#14B8A6</Color>

    <Color x:Key="PrimaryDarkColor">#115E59</Color>

    <Color x:Key="AccentColor">#F59E0B</Color>

    <Color x:Key="BackgroundColor">#F1F5F9</Color>

    <Color x:Key="SurfaceColor">#FFFFFF</Color>

    <Color x:Key="SidebarColor">#0F172A</Color>

    <Color x:Key="SidebarLightColor">#1E293B</Color>

    <Color x:Key="TextPrimaryColor">#0F172A</Color>

    <Color x:Key="TextSecondaryColor">#475569</Color>

    <Color x:Key="TextLightColor">#F8FAFC</Color>

    <Color x:Key="TextMutedColor">#94A3B8</Color>

    <Color x:Key="SuccessColor">#16A34A</Color>

    <Color x:Key="WarningColor">#D97706</Color>

    <Color x:Key="ErrorColor">#DC2626</Color>

    <Color x:Key="BorderColor">#E2E8F0</Color>



    <!-- ═══════════════════════════════════════════════════════════════════════════════ -->

    <!-- فرش الألوان الفريدة (Solid Color Brushes) -->

    <!-- ═══════════════════════════════════════════════════════════════════════════════ -->



    <SolidColorBrush x:Key="BrushAccentPrimary" Color="{StaticResource ColorAccentPrimary}"/>

    <SolidColorBrush x:Key="BrushAccentLight" Color="{StaticResource ColorAccentLight}"/>

    <SolidColorBrush x:Key="BrushAccentDark" Color="{StaticResource ColorAccentDark}"/>

    <SolidColorBrush x:Key="BrushAccentMuted" Color="{StaticResource ColorAccentMuted}"/>

    <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource ColorAccentPrimary}"/>



    <SolidColorBrush x:Key="BrushBackgroundMain" Color="{StaticResource ColorBackgroundMain}"/>

    <SolidColorBrush x:Key="BrushBackgroundHeader" Color="{StaticResource ColorBackgroundHeader}"/>

    <SolidColorBrush x:Key="BrushSurfaceCore" Color="{StaticResource ColorSurfaceCore}"/>

    <SolidColorBrush x:Key="BrushSidebarBackground" Color="{StaticResource ColorSidebarBackground}"/>

    <SolidColorBrush x:Key="BrushSidebarHover" Color="{StaticResource ColorSidebarHover}"/>



    <SolidColorBrush x:Key="BrushTextPrimary" Color="{StaticResource ColorTextPrimary}"/>

    <SolidColorBrush x:Key="BrushTextSecondary" Color="{StaticResource ColorTextSecondary}"/>

    <SolidColorBrush x:Key="BrushTextMuted" Color="{StaticResource ColorTextMuted}"/>

    <SolidColorBrush x:Key="BrushTextLight" Color="{StaticResource ColorTextLight}"/>



    <SolidColorBrush x:Key="BrushBorderDefault" Color="{StaticResource ColorBorderDefault}"/>

    <SolidColorBrush x:Key="BrushBorderLight" Color="{StaticResource ColorBorderLight}"/>



    <SolidColorBrush x:Key="BrushSuccess" Color="{StaticResource ColorSuccess}"/>

    <SolidColorBrush x:Key="BrushSuccessMuted" Color="{StaticResource ColorSuccessMuted}"/>

    <SolidColorBrush x:Key="BrushWarning" Color="{StaticResource ColorWarning}"/>

    <SolidColorBrush x:Key="BrushWarningMuted" Color="{StaticResource ColorWarningMuted}"/>

    <SolidColorBrush x:Key="BrushError" Color="{StaticResource ColorError}"/>

    <SolidColorBrush x:Key="BrushErrorMuted" Color="{StaticResource ColorErrorMuted}"/>

    <SolidColorBrush x:Key="BrushInfo" Color="{StaticResource ColorInfo}"/>

    <SolidColorBrush x:Key="BrushInfoMuted" Color="{StaticResource ColorInfoMuted}"/>



    <!-- Standard Brushes (mapped to design tokens) -->

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource ColorAccentPrimary}"/>

    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource ColorAccentLight}"/>

    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource ColorAccentDark}"/>



    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource ColorAccentLight}"/>

    <SolidColorBrush x:Key="SecondaryDarkBrush" Color="{StaticResource ColorAccentDark}"/>

    <SolidColorBrush x:Key="SecondaryLightBrush" Color="{StaticResource ColorAccentMuted}"/>



    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource ColorBackgroundMain}"/>

    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource ColorSurfaceCore}"/>

    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource ColorSidebarBackground}"/>

    <SolidColorBrush x:Key="SidebarLightBrush" Color="{StaticResource ColorSidebarHover}"/>

    <SolidColorBrush x:Key="SidebarHoverBrush" Color="{StaticResource ColorSidebarHover}"/>



    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource ColorTextPrimary}"/>

    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource ColorTextSecondary}"/>

    <SolidColorBrush x:Key="TextLightBrush" Color="{StaticResource ColorTextLight}"/>

    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource ColorTextMuted}"/>



    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource ColorBorderDefault}"/>

    <SolidColorBrush x:Key="BorderLightBrush" Color="{StaticResource ColorBorderLight}"/>

    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ColorError}"/>

    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource ColorError}"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource ColorSuccess}"/>

    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource ColorWarning}"/>

    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource ColorInfo}"/>



    <!-- Additional Design System Brushes (to replace inline hexes) -->

    <SolidColorBrush x:Key="BrushInputHover" Color="{StaticResource ColorAccentLight}"/>

    <SolidColorBrush x:Key="BrushInputFocusBg" Color="#F8FFF9"/> <!-- Soft light green for focused field background -->

    <SolidColorBrush x:Key="BrushDisabledBackground" Color="#E2E8F0"/>

    <SolidColorBrush x:Key="BrushDisabledBorder" Color="#CBD5E1"/>

    <SolidColorBrush x:Key="BrushDisabledText" Color="#94A3B8"/>

    

    <!-- DataGrid Colors mapped to Solid Color Brushes -->

    <Color x:Key="ColorDataGridHeader">#F0F6FA</Color>

    <SolidColorBrush x:Key="BrushDataGridHeader" Color="{StaticResource ColorDataGridHeader}"/>

    

    <Color x:Key="ColorDataGridSelected">#DDF4F1</Color>

    <SolidColorBrush x:Key="BrushDataGridSelected" Color="{StaticResource ColorDataGridSelected}"/>

    

    <Color x:Key="ColorDataGridGridLines">#ECF2F6</Color>

    <SolidColorBrush x:Key="BrushDataGridGridLines" Color="{StaticResource ColorDataGridGridLines}"/>

    

    <Color x:Key="ColorDataGridAlternatingRow">#F8FBFD</Color>

    <SolidColorBrush x:Key="BrushDataGridAlternatingRow" Color="{StaticResource ColorDataGridAlternatingRow}"/>

    

    <!-- Danger Hover Shadow -->

    <DropShadowEffect x:Key="DangerButtonShadow" BlurRadius="16" ShadowDepth="5" Direction="270" Opacity="0.24" Color="{StaticResource ColorError}"/>



    <!-- تدرجات لونية (Gradients) -->

    <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,1">

        <GradientStop Color="{StaticResource ColorAccentPrimary}" Offset="0"/>

        <GradientStop Color="{StaticResource ColorAccentLight}" Offset="1"/>

    </LinearGradientBrush>



    <LinearGradientBrush x:Key="SidebarGradient" StartPoint="0,0" EndPoint="0,1">

        <GradientStop Color="{StaticResource ColorSidebarBackground}" Offset="0"/>

        <GradientStop Color="{StaticResource ColorSidebarHover}" Offset="1"/>

    </LinearGradientBrush>



    <LinearGradientBrush x:Key="SecondaryGradient" StartPoint="0,0" EndPoint="1,1">

        <GradientStop Color="{StaticResource ColorAccentLight}" Offset="0"/>

        <GradientStop Color="{StaticResource ColorAccentPrimary}" Offset="1"/>

    </LinearGradientBrush>



    <LinearGradientBrush x:Key="SuccessGradient" StartPoint="0,0" EndPoint="1,1">

        <GradientStop Color="{StaticResource ColorSuccess}" Offset="0"/>

        <GradientStop Color="#22C55E" Offset="1"/>

    </LinearGradientBrush>



    <LinearGradientBrush x:Key="WarningGradient" StartPoint="0,0" EndPoint="1,1">

        <GradientStop Color="{StaticResource ColorWarning}" Offset="0"/>

        <GradientStop Color="#F59E0B" Offset="1"/>

    </LinearGradientBrush>



    <LinearGradientBrush x:Key="GlassGradient" StartPoint="0,0" EndPoint="1,1">

        <GradientStop Color="#95FFFFFF" Offset="0"/>

        <GradientStop Color="#70FFFFFF" Offset="1"/>

    </LinearGradientBrush>



    <!-- ═══════════════════════════════════════════════════════════════════════════════ -->

    <!-- رموز التباعد والأشكال (Spacing & Shape Tokens) -->

    <!-- ═══════════════════════════════════════════════════════════════════════════════ -->



    <!-- Corner Radii -->

    <CornerRadius x:Key="CornerRadiusCardLarge">18</CornerRadius>

    <CornerRadius x:Key="CornerRadiusCardNormal">12</CornerRadius>

    <CornerRadius x:Key="CornerRadiusControlLarge">14</CornerRadius>

    <CornerRadius x:Key="CornerRadiusControlNormal">12</CornerRadius>

    <CornerRadius x:Key="CornerRadiusControlSmall">8</CornerRadius>



    <!-- Spacing (Thickness) -->

    <Thickness x:Key="PaddingCardLarge">24</Thickness>

    <Thickness x:Key="PaddingCardNormal">16</Thickness>

    <Thickness x:Key="PaddingControlNormal">16,12</Thickness>

    <Thickness x:Key="PaddingControlDense">12,8</Thickness>

    <Thickness x:Key="PaddingControlSmall">8,4</Thickness>

    <Thickness x:Key="MarginStackNormal">0,0,0,12</Thickness>

    <Thickness x:Key="MarginStackSmall">0,0,0,6</Thickness>



    <!-- ═══════════════════════════════════════════════════════════════════════════════ -->

    <!-- رموز الظلال والارتفاع (Elevation & Shadow Tokens) -->

    <!-- ═══════════════════════════════════════════════════════════════════════════════ -->



    <DropShadowEffect x:Key="ElevationShadowLow" BlurRadius="12" ShadowDepth="2" Direction="270" Opacity="0.08" Color="{StaticResource ColorSidebarBackground}"/>

    <DropShadowEffect x:Key="ElevationShadowMedium" BlurRadius="24" ShadowDepth="6" Direction="270" Opacity="0.12" Color="{StaticResource ColorSidebarBackground}"/>

    <DropShadowEffect x:Key="ElevationShadowHigh" BlurRadius="36" ShadowDepth="12" Direction="270" Opacity="0.16" Color="{StaticResource ColorSidebarBackground}"/>

    <DropShadowEffect x:Key="AccentShadow" BlurRadius="16" ShadowDepth="4" Direction="270" Opacity="0.25" Color="{StaticResource ColorAccentPrimary}"/>

    <DropShadowEffect x:Key="ErrorGlowEffect" BlurRadius="8" ShadowDepth="0" Direction="0" Opacity="0.3" Color="{StaticResource ColorError}"/>



    <!-- Backward Compatibility Shadow Aliases -->

    <DropShadowEffect x:Key="CardShadow" BlurRadius="24" ShadowDepth="6" Direction="270" Opacity="0.11" Color="{StaticResource ColorSidebarBackground}"/>

    <DropShadowEffect x:Key="CardShadowHover" BlurRadius="34" ShadowDepth="12" Direction="270" Opacity="0.2" Color="{StaticResource ColorAccentPrimary}"/>

    <DropShadowEffect x:Key="ButtonShadow" BlurRadius="16" ShadowDepth="5" Direction="270" Opacity="0.24" Color="{StaticResource ColorAccentPrimary}"/>

    <DropShadowEffect x:Key="DropdownShadow" BlurRadius="24" ShadowDepth="8" Direction="270" Opacity="0.14" Color="{StaticResource ColorSidebarBackground}"/>

    <DropShadowEffect x:Key="InputFocusGlow" BlurRadius="12" ShadowDepth="0" Direction="0" Opacity="0.24" Color="{StaticResource ColorSuccess}"/>

    <DropShadowEffect x:Key="GlowEffect" BlurRadius="18" ShadowDepth="0" Direction="0" Opacity="0.35" Color="{StaticResource ColorSuccess}"/>

    <DropShadowEffect x:Key="DefaultShadow" BlurRadius="18" ShadowDepth="3" Direction="270" Opacity="0.12" Color="{StaticResource ColorSidebarBackground}"/>



    <!-- أنماط الأزرار (Button Styles) -->

    <!-- ═══════════════════════════════════════════════════════════════════════════════ -->



    <!-- زر أساسي (Primary Button) -->

    <Style x:Key="PrimaryButton" TargetType="Button">

        <Setter Property="Background" Value="{StaticResource PrimaryGradient}"/>

        <Setter Property="Foreground" Value="White"/>

        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>

        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>

        <Setter Property="FontWeight" Value="{StaticResource FontWeightSemiBold}"/>

        <Setter Property="Padding" Value="{StaticResource PaddingControlNormal}"/>

        <Setter Property="MinHeight" Value="42"/>

        <Setter Property="Cursor" Value="Hand"/>

        <Setter Property="BorderThickness" Value="1"/>

        <Setter Property="BorderBrush" Value="Transparent"/>

        <Setter Property="Template">

            <Setter.Value>

                <ControlTemplate TargetType="Button">

                    <Border x:Name="BorderRoot"

                            Background="{TemplateBinding Background}"

                            BorderBrush="{TemplateBinding BorderBrush}"

                            BorderThickness="{TemplateBinding BorderThickness}"

                            CornerRadius="{StaticResource CornerRadiusControlNormal}"

                            Effect="{x:Null}"

                            Padding="{TemplateBinding Padding}">

                        <ContentPresenter HorizontalAlignment="Center"

                                          VerticalAlignment="Center"/>

                    </Border>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">

                            <Setter TargetName="BorderRoot" Property="Effect" Value="{StaticResource ButtonShadow}"/>

                            <Setter TargetName="BorderRoot" Property="Opacity" Value="0.97"/>

                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">

                            <Setter TargetName="BorderRoot" Property="Opacity" Value="0.9"/>

                        </Trigger>

                        <Trigger Property="IsFocused" Value="True">

                            <Setter TargetName="BorderRoot" Property="BorderBrush" Value="{StaticResource BrushAccent}"/>

                            <Setter TargetName="BorderRoot" Property="BorderThickness" Value="2"/>

                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">

                            <Setter TargetName="BorderRoot" Property="Background" Value="{StaticResource BrushDisabledBackground}"/>

                            <Setter TargetName="BorderRoot" Property="BorderBrush" Value="{StaticResource BrushDisabledBorder}"/>

                            <Setter Property="Foreground" Value="{StaticResource BrushDisabledText}"/>

                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>

            </Setter.Value>

        </Setter>

    </Style>



    <!-- زر أيقونة (Icon Button) -->

    <Style x:Key="IconButton" TargetType="Button">

        <Setter Property="Background" Value="Transparent"/>

        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>

        <Setter Property="Width" Value="42"/>

        <Setter Property="Height" Value="42"/>

        <Setter Property="Cursor" Value="Hand"/>

        <Setter Property="BorderThickness" Value="0"/>

        <Setter Property="Template">

            <Setter.Value>

                <ControlTemplate TargetType="Button">

                    <Border x:Name="IconBorder" Background="{TemplateBinding Background}" BorderBrush="Transparent" BorderThickness="0" CornerRadius="{StaticResource CornerRadiusControlNormal}">

                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    </Border>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">

                            <Setter TargetName="IconBorder" Property="Background" Value="{StaticResource BrushAccentMuted}"/>

                            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>

                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">

                            <Setter TargetName="IconBorder" Property="Opacity" Value="0.82"/>

                        </Trigger>

                        <Trigger Property="IsFocused" Value="True">

                            <Setter TargetName="IconBorder" Property="BorderBrush" Value="{StaticResource BrushAccent}"/>

                            <Setter TargetName="IconBorder" Property="BorderThickness" Value="1"/>

                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">

                            <Setter Property="Foreground" Value="{StaticResource BrushDisabledText}"/>

                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>

            </Setter.Value>

        </Setter>

    </Style>



    <!-- زر القائمة الجانبية (Sidebar Button) -->

    <Style x:Key="SidebarButton" TargetType="Button">

        <Setter Property="Background" Value="Transparent"/>

        <Setter Property="Foreground" Value="#B4C7D6"/>

        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>

        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>

        <Setter Property="FontWeight" Value="{StaticResource FontWeightRegular}"/>

        <Setter Property="Padding" Value="{StaticResource PaddingControlNormal}"/>

        <Setter Property="Margin" Value="10,3"/>

        <Setter Property="HorizontalContentAlignment" Value="Right"/>

        <Setter Property="Cursor" Value="Hand"/>

        <Setter Property="BorderThickness" Value="0"/>

        <Setter Property="Template">

            <Setter.Value>

                <ControlTemplate TargetType="Button">

                    <Border x:Name="SidebarButtonBorder"

                            Background="{TemplateBinding Background}"

                            BorderBrush="Transparent"

                            BorderThickness="0"

                            Effect="{x:Null}"

                            CornerRadius="{StaticResource CornerRadiusControlNormal}"

                            Padding="{TemplateBinding Padding}">

                        <Grid>

                            <Border x:Name="ActiveMarker"

                                    Width="4"

                                    HorizontalAlignment="Right"

                                    Background="#60FFFFFF"

                                    CornerRadius="4"

                                    Margin="0,3,0,3"

                                    Visibility="Collapsed"/>

                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"

                                              VerticalAlignment="Center"

                                              Margin="0,0,14,0"/>

                        </Grid>

                    </Border>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">

                            <Setter TargetName="SidebarButtonBorder" Property="Background" Value="{StaticResource SidebarHoverBrush}"/>

                            <Setter Property="Foreground" Value="#F8FAFC"/>

                        </Trigger>

                        <Trigger Property="IsFocused" Value="True">

                            <Setter TargetName="SidebarButtonBorder" Property="BorderBrush" Value="#40FFFFFF"/>

                            <Setter TargetName="SidebarButtonBorder" Property="BorderThickness" Value="1"/>

                        </Trigger>

                        <Trigger Property="Tag" Value="Active">

                            <Setter TargetName="SidebarButtonBorder" Property="Background" Value="{StaticResource PrimaryGradient}"/>

                            <Setter TargetName="SidebarButtonBorder" Property="Effect">

                                <Setter.Value>

                                    <DropShadowEffect BlurRadius="14" ShadowDepth="2" Direction="270" Opacity="0.35" Color="#14B8A6"/>

                                </Setter.Value>

                            </Setter>

                            <Setter TargetName="ActiveMarker" Property="Visibility" Value="Visible"/>

                            <Setter Property="Foreground" Value="White"/>

                            <Setter Property="FontWeight" Value="{StaticResource FontWeightSemiBold}"/>

                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>

            </Setter.Value>

        </Setter>

    </Style>



    <!-- ═══════════════════════════════════════════════════════════════════════════════ -->

    <!-- أنماط عامة أخرى (General Styles) -->

    <!-- ═══════════════════════════════════════════════════════════════════════════════ -->



    <!-- Card Container -->

    <Style x:Key="CardDetail" TargetType="Border">

        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>

        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusCardNormal}"/>

        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>

        <Setter Property="BorderThickness" Value="1"/>

        <Setter Property="Effect" Value="{StaticResource CardShadow}"/>

    </Style>



    <!-- Modern TextBox -->

    <Style x:Key="ModernTextBox" TargetType="TextBox">

        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>

        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>

        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>

        <Setter Property="BorderThickness" Value="1"/>

        <Setter Property="Effect" Value="{x:Null}"/>

        <Setter Property="Padding" Value="{StaticResource PaddingControlDense}"/>

        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>

        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>

        <Setter Property="FlowDirection" Value="RightToLeft"/>

        <Setter Property="Template">

            <Setter.Value>

                <ControlTemplate TargetType="TextBox">

                    <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="{StaticResource CornerRadiusControlNormal}" Effect="{x:Null}">

                        <ScrollViewer x:Name="PART_ContentHost" Margin="0" Padding="{TemplateBinding Padding}" VerticalAlignment="Center"/>

                    </Border>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">

                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BrushInputHover}"/>

                        </Trigger>

                        <Trigger Property="IsFocused" Value="True">

                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BrushAccent}"/>

                            <Setter TargetName="border" Property="BorderThickness" Value="2"/>

                            <Setter TargetName="border" Property="Background" Value="{StaticResource BrushInputFocusBg}"/>

                        </Trigger>

                        <Trigger Property="Validation.HasError" Value="True">

                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource ErrorBrush}"/>

                            <Setter TargetName="border" Property="Effect" Value="{StaticResource ErrorGlowEffect}"/>

                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">

                            <Setter TargetName="border" Property="Background" Value="{StaticResource BrushDisabledBackground}"/>

                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BrushDisabledBorder}"/>

                            <Setter Property="Foreground" Value="{StaticResource BrushDisabledText}"/>

                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>

            </Setter.Value>

        </Setter>

    </Style>



    <!-- Modern DataGrid -->

    <Style x:Key="ModernDataGridStyle" TargetType="DataGrid">

        <Setter Property="Background" Value="White"/>

        <Setter Property="BorderThickness" Value="0"/>

        <Setter Property="RowHeight" Value="48"/>

        <Setter Property="GridLinesVisibility" Value="Horizontal"/>

        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BrushDataGridGridLines}"/>

        <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>

        <Setter Property="AlternatingRowBackground" Value="{StaticResource BrushDataGridAlternatingRow}"/>

        <Setter Property="CanUserAddRows" Value="False"/>

        <Setter Property="CanUserDeleteRows" Value="False"/>

        <Setter Property="IsReadOnly" Value="True"/>

        <Setter Property="AutoGenerateColumns" Value="False"/>

        <Setter Property="SelectionMode" Value="Single"/>

        <Setter Property="SelectionUnit" Value="FullRow"/>

        <Setter Property="HeadersVisibility" Value="Column"/>

        <Setter Property="EnableRowVirtualization" Value="True"/>

        <Setter Property="EnableColumnVirtualization" Value="True"/>

        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>

        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>

        <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>

        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>

        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>



        <Setter Property="ColumnHeaderStyle">

            <Setter.Value>

                <Style TargetType="DataGridColumnHeader">

                    <Setter Property="Background" Value="{StaticResource BrushDataGridHeader}"/>

                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>

                    <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>

                    <Setter Property="FontWeight" Value="{StaticResource FontWeightSemiBold}"/>

                    <Setter Property="Padding" Value="{StaticResource PaddingControlNormal}"/>

                    <Setter Property="BorderThickness" Value="0,0,0,1"/>

                    <Setter Property="BorderBrush" Value="{StaticResource BrushBorderDefault}"/>

                    <Setter Property="HorizontalContentAlignment" Value="Right"/>

                </Style>

            </Setter.Value>

        </Setter>



        <Setter Property="CellStyle">

            <Setter.Value>

                <Style TargetType="DataGridCell">

                    <Setter Property="Padding" Value="16,8"/>

                    <Setter Property="BorderThickness" Value="1"/>

                    <Setter Property="BorderBrush" Value="Transparent"/>

                    <Setter Property="Template">

                        <Setter.Value>

                            <ControlTemplate TargetType="DataGridCell">

                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">

                                    <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Right"/>

                                </Border>

                            </ControlTemplate>

                        </Setter.Value>

                    </Setter>

                    <Style.Triggers>

                        <Trigger Property="IsSelected" Value="True">

                            <Setter Property="Background" Value="{StaticResource BrushDataGridSelected}"/>

                            <Setter Property="Foreground" Value="{StaticResource PrimaryDarkBrush}"/>

                            <Setter Property="FontWeight" Value="{StaticResource FontWeightSemiBold}"/>

                        </Trigger>

                        <Trigger Property="IsMouseOver" Value="True">

                            <Setter Property="Background" Value="{StaticResource BrushAccentMuted}"/>

                        </Trigger>

                        <Trigger Property="IsFocused" Value="True">

                            <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>

                        </Trigger>

                    </Style.Triggers>

                </Style>

            </Setter.Value>

        </Setter>

    </Style>



    <!-- ═══════════════════════════════════════════════════════════════════════════════ -->

    <!-- أنماط الأزرار الإضافية -->

    <!-- ═══════════════════════════════════════════════════════════════════════════════ -->



    <!-- زر ثانوي -->

    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">

        <Setter Property="Background" Value="{StaticResource SecondaryGradient}"/>

    </Style>



    <!-- زر محيط (Outline) -->

    <Style x:Key="OutlineButton" TargetType="Button">

        <Setter Property="Background" Value="Transparent"/>

        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>

        <Setter Property="BorderBrush" Value="{StaticResource PrimaryLightBrush}"/>

        <Setter Property="BorderThickness" Value="1.5"/>

        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>

        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>

        <Setter Property="FontWeight" Value="{StaticResource FontWeightSemiBold}"/>

        <Setter Property="Padding" Value="{StaticResource PaddingControlNormal}"/>

        <Setter Property="Cursor" Value="Hand"/>

        <Setter Property="Template">

            <Setter.Value>

                <ControlTemplate TargetType="Button">

                    <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="{StaticResource CornerRadiusControlNormal}" Padding="{TemplateBinding Padding}">

                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    </Border>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">

                            <Setter TargetName="border" Property="Background" Value="{StaticResource BrushAccentMuted}"/>

                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>

                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">

                            <Setter TargetName="border" Property="Opacity" Value="0.88"/>

                        </Trigger>

                        <Trigger Property="IsFocused" Value="True">

                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BrushAccent}"/>

                            <Setter TargetName="border" Property="BorderThickness" Value="2"/>

                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">

                            <Setter TargetName="border" Property="Background" Value="{StaticResource BrushDisabledBackground}"/>

                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BrushDisabledBorder}"/>

                            <Setter Property="Foreground" Value="{StaticResource BrushDisabledText}"/>

                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>

            </Setter.Value>

        </Setter>

    </Style>



    <!-- زر خطر (Danger) -->

    <Style x:Key="DangerButton" TargetType="Button">

        <Setter Property="Background" Value="{StaticResource ErrorBrush}"/>

        <Setter Property="Foreground" Value="White"/>

        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>

        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>

        <Setter Property="FontWeight" Value="{StaticResource FontWeightBold}"/>

        <Setter Property="Padding" Value="{StaticResource PaddingControlNormal}"/>

        <Setter Property="MinHeight" Value="42"/>

        <Setter Property="Cursor" Value="Hand"/>

        <Setter Property="BorderThickness" Value="1"/>

        <Setter Property="BorderBrush" Value="Transparent"/>

        <Setter Property="Template">

            <Setter.Value>

                <ControlTemplate TargetType="Button">

                    <Border x:Name="BorderRoot"

                            Background="{TemplateBinding Background}"

                            BorderBrush="{TemplateBinding BorderBrush}"

                            BorderThickness="{TemplateBinding BorderThickness}"

                            CornerRadius="{StaticResource CornerRadiusControlNormal}"

                            Effect="{x:Null}"

                            Padding="{TemplateBinding Padding}">

                        <ContentPresenter HorizontalAlignment="Center"

                                          VerticalAlignment="Center"/>

                    </Border>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">

                            <Setter TargetName="BorderRoot" Property="Effect" Value="{StaticResource DangerButtonShadow}"/>

                            <Setter TargetName="BorderRoot" Property="Opacity" Value="0.97"/>

                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">

                            <Setter TargetName="BorderRoot" Property="Opacity" Value="0.9"/>

                        </Trigger>

                        <Trigger Property="IsFocused" Value="True">

                            <Setter TargetName="BorderRoot" Property="BorderBrush" Value="{StaticResource BrushAccent}"/>

                            <Setter TargetName="BorderRoot" Property="BorderThickness" Value="2"/>

                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">

                            <Setter TargetName="BorderRoot" Property="Background" Value="{StaticResource BrushDisabledBackground}"/>

                            <Setter TargetName="BorderRoot" Property="BorderBrush" Value="{StaticResource BrushDisabledBorder}"/>

                            <Setter Property="Foreground" Value="{StaticResource BrushDisabledText}"/>

                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>

            </Setter.Value>

        </Setter>

    </Style>



    <!-- زر نصي (Text Button) -->

    <Style x:Key="TextButton" TargetType="Button">

        <Setter Property="Background" Value="Transparent"/>

        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>

        <Setter Property="Padding" Value="{StaticResource PaddingControlSmall}"/>

        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>

        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>

        <Setter Property="Cursor" Value="Hand"/>

        <Setter Property="BorderThickness" Value="0"/>

        <Setter Property="Template">

            <Setter.Value>

                <ControlTemplate TargetType="Button">

                    <Border x:Name="TextButtonBorder" Background="{TemplateBinding Background}" BorderBrush="Transparent" BorderThickness="0" CornerRadius="{StaticResource CornerRadiusControlSmall}" Padding="{TemplateBinding Padding}">

                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    </Border>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">

                            <Setter TargetName="TextButtonBorder" Property="Background" Value="{StaticResource BrushAccentMuted}"/>

                        </Trigger>

                        <Trigger Property="IsFocused" Value="True">

                            <Setter TargetName="TextButtonBorder" Property="Background" Value="{StaticResource BrushAccentMuted}"/>

                            <Setter TargetName="TextButtonBorder" Property="BorderBrush" Value="{StaticResource BrushAccent}"/>

                            <Setter TargetName="TextButtonBorder" Property="BorderThickness" Value="1"/>

                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">

                            <Setter Property="Foreground" Value="{StaticResource BrushDisabledText}"/>

                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>

            </Setter.Value>

        </Setter>

    </Style>



    <!-- زر إجراء (Action Button) -->

    <Style x:Key="ActionButton" TargetType="Button">

        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>

        <Setter Property="Foreground" Value="White"/>

        <Setter Property="Padding" Value="{StaticResource PaddingControlDense}"/>

        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>

        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>

        <Setter Property="FontWeight" Value="{StaticResource FontWeightSemiBold}"/>

        <Setter Property="Cursor" Value="Hand"/>

        <Setter Property="BorderThickness" Value="0"/>

        <Setter Property="Template">

            <Setter.Value>

                <ControlTemplate TargetType="Button">

                    <Border x:Name="ActionBorder" Background="{TemplateBinding Background}" BorderBrush="Transparent" BorderThickness="0" CornerRadius="{StaticResource CornerRadiusControlSmall}" Padding="{TemplateBinding Padding}">

                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    </Border>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">

                            <Setter TargetName="ActionBorder" Property="Opacity" Value="0.92"/>

                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">

                            <Setter TargetName="ActionBorder" Property="Opacity" Value="0.82"/>

                        </Trigger>

                        <Trigger Property="IsFocused" Value="True">

                            <Setter TargetName="ActionBorder" Property="BorderBrush" Value="{StaticResource BrushAccent}"/>

                            <Setter TargetName="ActionBorder" Property="BorderThickness" Value="1"/>

                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">

                            <Setter TargetName="ActionBorder" Property="Background" Value="{StaticResource BrushDisabledBackground}"/>

                            <Setter Property="Foreground" Value="{StaticResource BrushDisabledText}"/>

                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>

            </Setter.Value>

        </Setter>

    </Style>



    <!-- ═══════════════════════════════════════════════════════════════════════════════ -->

    <!-- أنماط البطاقات -->

    <!-- ═══════════════════════════════════════════════════════════════════════════════ -->



    <!-- بطاقة عادية -->

    <Style x:Key="CardBorder" TargetType="Border">

        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>

        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusCardLarge}"/>

        <Setter Property="Padding" Value="{StaticResource PaddingCardLarge}"/>

        <Setter Property="Effect" Value="{StaticResource CardShadow}"/>

        <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>

        <Setter Property="BorderThickness" Value="1"/>

    </Style>



    <!-- بطاقة إحصائيات -->

    <Style x:Key="StatCard" TargetType="Border">

        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>

        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusCardLarge}"/>

        <Setter Property="Padding" Value="{StaticResource PaddingCardLarge}"/>

        <Setter Property="Effect" Value="{StaticResource CardShadow}"/>

        <Setter Property="MinWidth" Value="210"/>

        <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>

        <Setter Property="BorderThickness" Value="1"/>

    </Style>

    <!-- Modern Password Box -->

    <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">

        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>

        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>

        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>

        <Setter Property="BorderThickness" Value="1"/>

        <Setter Property="Effect" Value="{x:Null}"/>

        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>

        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>

        <Setter Property="Padding" Value="{StaticResource PaddingControlDense}"/>

        <Setter Property="FlowDirection" Value="LeftToRight"/>

        <Setter Property="Template">

            <Setter.Value>

                <ControlTemplate TargetType="PasswordBox">

                    <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="{StaticResource CornerRadiusControlNormal}" Effect="{x:Null}">

                        <ScrollViewer x:Name="PART_ContentHost" Margin="0" Padding="{TemplateBinding Padding}" VerticalAlignment="Center"/>

                    </Border>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">

                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BrushInputHover}"/>

                        </Trigger>

                        <Trigger Property="IsFocused" Value="True">

                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BrushAccent}"/>

                            <Setter TargetName="border" Property="BorderThickness" Value="2"/>

                            <Setter TargetName="border" Property="Background" Value="{StaticResource BrushInputFocusBg}"/>

                        </Trigger>

                        <Trigger Property="Validation.HasError" Value="True">

                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource ErrorBrush}"/>

                            <Setter TargetName="border" Property="Effect" Value="{StaticResource ErrorGlowEffect}"/>

                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">

                            <Setter TargetName="border" Property="Background" Value="{StaticResource BrushDisabledBackground}"/>

                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BrushDisabledBorder}"/>

                            <Setter Property="Foreground" Value="{StaticResource BrushDisabledText}"/>

                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>

            </Setter.Value>

        </Setter>

    </Style>



    <!-- Helper ToggleButton template for ComboBox -->

    <Style x:Key="ComboBoxToggleButton" TargetType="ToggleButton">

        <Setter Property="OverridesDefaultStyle" Value="True"/>

        <Setter Property="IsTabStop" Value="False"/>

        <Setter Property="Focusable" Value="False"/>

        <Setter Property="ClickMode" Value="Press"/>

        <Setter Property="Template">

            <Setter.Value>

                <ControlTemplate TargetType="ToggleButton">

                    <Border x:Name="templateRoot" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="{StaticResource CornerRadiusControlNormal}">

                        <Grid>

                            <Grid.ColumnDefinitions>

                                <ColumnDefinition Width="*"/>

                                <ColumnDefinition Width="36"/>

                            </Grid.ColumnDefinitions>

                            <Path x:Name="arrow" Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z" Fill="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        </Grid>

                    </Border>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">

                            <Setter TargetName="templateRoot" Property="BorderBrush" Value="{StaticResource BrushInputHover}"/>

                            <Setter TargetName="arrow" Property="Fill" Value="{StaticResource PrimaryBrush}"/>

                        </Trigger>

                        <Trigger Property="IsChecked" Value="True">

                            <Setter TargetName="arrow" Property="Fill" Value="{StaticResource PrimaryBrush}"/>

                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>

            </Setter.Value>

        </Setter>

    </Style>



    <!-- Modern ComboBox -->

    <Style x:Key="ModernComboBox" TargetType="ComboBox">

        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>

        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>

        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>

        <Setter Property="BorderThickness" Value="1"/>

        <Setter Property="Effect" Value="{x:Null}"/>

        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>

        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>

        <Setter Property="Padding" Value="12,8"/>

        <Setter Property="FlowDirection" Value="RightToLeft"/>

        <Setter Property="Template">

            <Setter.Value>

                <ControlTemplate TargetType="ComboBox">

                    <Grid x:Name="templateRoot" SnapsToDevicePixels="True">

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="*"/>

                            <ColumnDefinition Width="Auto"/>

                        </Grid.ColumnDefinitions>

                        

                        <ToggleButton x:Name="toggleButton" Grid.ColumnSpan="2"

                                      Background="{TemplateBinding Background}"

                                      BorderBrush="{TemplateBinding BorderBrush}"

                                      BorderThickness="{TemplateBinding BorderThickness}"

                                      Style="{StaticResource ComboBoxToggleButton}"

                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>

                                      

                        <ContentPresenter x:Name="contentPresenter"

                                          Grid.Column="0"

                                          Content="{TemplateBinding SelectionBoxItem}"

                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"

                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"

                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"

                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"

                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"

                                          Margin="{TemplateBinding Padding}"

                                          IsHitTestVisible="False"

                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>

                                          

                        <Popup x:Name="presenterSourcePopup"

                               Placement="Bottom"

                               IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"

                               AllowsTransparency="True"

                               Focusable="False"

                               PopupAnimation="Slide">

                            <Border x:Name="dropDownBorder"

                                    MinWidth="{Binding ActualWidth, ElementName=templateRoot}"

                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"

                                    Background="{StaticResource SurfaceBrush}"

                                    BorderBrush="{StaticResource BorderBrush}"

                                    BorderThickness="1"

                                    CornerRadius="{StaticResource CornerRadiusControlNormal}"

                                    Effect="{StaticResource DropdownShadow}"

                                    Margin="0,4,0,4">

                                <ScrollViewer x:Name="dropDownScrollViewer" MaxHeight="{TemplateBinding MaxDropDownHeight}">

                                    <Grid x:Name="grid" RenderOptions.ClearTypeHint="Enabled">

                                        <Canvas x:Name="canvas" HorizontalAlignment="Left" Height="0" VerticalAlignment="Top" Width="0">

                                            <Rectangle x:Name="opaqueRect" Fill="{Binding Background, ElementName=dropDownBorder}" Height="{Binding ActualHeight, ElementName=dropDownBorder}" Width="{Binding ActualWidth, ElementName=dropDownBorder}"/>

                                        </Canvas>

                                        <ItemsPresenter x:Name="itemsPresenter" KeyboardNavigation.DirectionalNavigation="Contained" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>

                                    </Grid>

                                </ScrollViewer>

                            </Border>

                        </Popup>

                    </Grid>

                    <ControlTemplate.Triggers>

                        <Trigger Property="HasItems" Value="False">

                            <Setter TargetName="dropDownBorder" Property="Height" Value="95"/>

                        </Trigger>

                        <Trigger Property="IsMouseOver" Value="True">

                            <Setter TargetName="toggleButton" Property="BorderBrush" Value="{StaticResource BrushInputHover}"/>

                        </Trigger>

                        <Trigger Property="IsKeyboardFocusWithin" Value="True">

                            <Setter TargetName="toggleButton" Property="BorderBrush" Value="{StaticResource BrushAccent}"/>

                            <Setter TargetName="toggleButton" Property="BorderThickness" Value="2"/>

                            <Setter TargetName="toggleButton" Property="Background" Value="{StaticResource BrushInputFocusBg}"/>

                        </Trigger>

                        <Trigger Property="Validation.HasError" Value="True">

                            <Setter TargetName="toggleButton" Property="BorderBrush" Value="{StaticResource ErrorBrush}"/>

                            <Setter TargetName="toggleButton" Property="Effect" Value="{StaticResource ErrorGlowEffect}"/>

                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">

                            <Setter TargetName="toggleButton" Property="Background" Value="{StaticResource BrushDisabledBackground}"/>

                            <Setter TargetName="toggleButton" Property="BorderBrush" Value="{StaticResource BrushDisabledBorder}"/>

                            <Setter Property="Foreground" Value="{StaticResource BrushDisabledText}"/>

                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>

            </Setter.Value>

        </Setter>

    </Style>



    <!-- ComboBoxItem Style -->

    <Style TargetType="ComboBoxItem">

        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>

        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>

        <Setter Property="Padding" Value="12,8"/>

        <Setter Property="Background" Value="Transparent"/>

        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>

        <Setter Property="FlowDirection" Value="RightToLeft"/>

        <Setter Property="Template">

            <Setter.Value>

                <ControlTemplate TargetType="ComboBoxItem">

                    <Border x:Name="itemBorder" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="{StaticResource CornerRadiusControlSmall}" Margin="4,2">

                        <ContentPresenter HorizontalAlignment="Right" VerticalAlignment="Center"/>

                    </Border>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">

                            <Setter TargetName="itemBorder" Property="Background" Value="{StaticResource BrushAccentMuted}"/>

                            <Setter Property="Foreground" Value="{StaticResource PrimaryDarkBrush}"/>

                        </Trigger>

                        <Trigger Property="IsSelected" Value="True">

                            <Setter TargetName="itemBorder" Property="Background" Value="{StaticResource BrushDataGridSelected}"/>

                            <Setter Property="Foreground" Value="{StaticResource PrimaryDarkBrush}"/>

                            <Setter Property="FontWeight" Value="{StaticResource FontWeightSemiBold}"/>

                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>

            </Setter.Value>

        </Setter>

    </Style>



    <!-- Helper Style for DatePickerTextBox to look clean and transparent -->

    <Style TargetType="DatePickerTextBox">

        <Setter Property="Background" Value="Transparent"/>

        <Setter Property="BorderThickness" Value="0"/>

        <Setter Property="Padding" Value="0"/>

        <Setter Property="VerticalContentAlignment" Value="Center"/>

        <Setter Property="Template">

            <Setter.Value>

                <ControlTemplate TargetType="DatePickerTextBox">

                    <ScrollViewer x:Name="PART_ContentHost" Background="Transparent" Focusable="False" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>

                </ControlTemplate>

            </Setter.Value>
        </Setter>

    </Style>



    <!-- Modern DatePicker -->

    <Style x:Key="ModernDatePicker" TargetType="DatePicker">

        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>

        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>

        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>

        <Setter Property="BorderThickness" Value="1"/>

        <Setter Property="Effect" Value="{x:Null}"/>

        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>

        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>

        <Setter Property="Padding" Value="12,8"/>

        <Setter Property="FlowDirection" Value="RightToLeft"/>

        <Setter Property="SelectedDateFormat" Value="Short"/>

        <Setter Property="Template">

            <Setter.Value>

                <ControlTemplate TargetType="DatePicker">

                    <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="{StaticResource CornerRadiusControlNormal}">

                        <Grid x:Name="PART_Root" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

                            <Grid.ColumnDefinitions>

                                <ColumnDefinition Width="*"/>

                                <ColumnDefinition Width="Auto"/>

                            </Grid.ColumnDefinitions>

                            

                            <DatePickerTextBox x:Name="PART_TextBox" Grid.Column="0"

                                               HorizontalContentAlignment="Stretch"

                                               VerticalContentAlignment="Center"

                                               Focusable="{TemplateBinding Focusable}"

                                               Background="Transparent"

                                               BorderThickness="0"

                                               Padding="{TemplateBinding Padding}"

                                               FontFamily="{TemplateBinding FontFamily}"

                                               FontSize="{TemplateBinding FontSize}"/>

                                               

                            <Button x:Name="PART_Button" Grid.Column="1"

                                    Width="36"

                                    Height="Auto"

                                    Background="Transparent"

                                    BorderThickness="0"

                                    Cursor="Hand"

                                    Focusable="False">

                                <Button.Template>

                                    <ControlTemplate TargetType="Button">

                                        <Border x:Name="btnBorder" Background="Transparent" CornerRadius="0,8,8,0">

                                            <Path x:Name="calIcon" Data="M 2 0 L 14 0 C 15.1 0 16 0.9 16 2 L 16 14 C 16 15.1 15.1 16 14 16 L 2 16 C 0.9 16 0 15.1 0 14 L 0 2 C 0 0.9 0.9 0 2 0 Z M 2 2 L 2 4 L 14 4 L 14 2 Z M 2 6 L 2 14 L 14 14 L 14 6 Z M 4 8 L 6 8 L 6 10 L 4 10 Z M 8 8 L 10 8 L 10 10 L 8 10 Z M 4 11 L 6 11 L 6 13 L 4 13 Z M 8 11 L 10 11 L 10 13 L 8 13 Z"

                                                  Fill="{StaticResource TextSecondaryBrush}"

                                                  Stretch="Uniform"

                                                  Width="16" Height="16"

                                                  HorizontalAlignment="Center"

                                                  VerticalAlignment="Center"/>

                                        </Border>

                                        <ControlTemplate.Triggers>

                                            <Trigger Property="IsMouseOver" Value="True">

                                                <Setter TargetName="btnBorder" Property="Background" Value="{StaticResource BrushAccentMuted}"/>

                                                <Setter TargetName="calIcon" Property="Fill" Value="{StaticResource PrimaryBrush}"/>

                                            </Trigger>

                                        </ControlTemplate.Triggers>

                                    </ControlTemplate>

                                </Button.Template>

                            </Button>

                            

                            <Popup x:Name="PART_Popup" AllowsTransparency="True" Placement="Bottom" PlacementTarget="{Binding ElementName=PART_TextBox}" StaysOpen="False"/>

                        </Grid>

                    </Border>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">

                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BrushInputHover}"/>

                        </Trigger>

                        <Trigger Property="IsKeyboardFocusWithin" Value="True">

                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BrushAccent}"/>

                            <Setter TargetName="border" Property="BorderThickness" Value="2"/>

                            <Setter TargetName="border" Property="Background" Value="{StaticResource BrushInputFocusBg}"/>

                        </Trigger>

                        <Trigger Property="Validation.HasError" Value="True">

                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource ErrorBrush}"/>

                            <Setter TargetName="border" Property="Effect" Value="{StaticResource ErrorGlowEffect}"/>

                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">

                            <Setter TargetName="border" Property="Background" Value="{StaticResource BrushDisabledBackground}"/>

                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BrushDisabledBorder}"/>

                            <Setter Property="Foreground" Value="{StaticResource BrushDisabledText}"/>

                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>

            </Setter.Value>

        </Setter>

    </Style>



    <!-- Modern CheckBox -->

    <Style x:Key="ModernCheckBox" TargetType="CheckBox">

        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>

        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>

        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>

        <Setter Property="VerticalContentAlignment" Value="Center"/>

        <Setter Property="HorizontalContentAlignment" Value="Left"/>

        <Setter Property="Padding" Value="8,0,8,0"/>

        <Setter Property="Cursor" Value="Hand"/>

        <Setter Property="Template">

            <Setter.Value>

                <ControlTemplate TargetType="CheckBox">

                    <Grid x:Name="templateRoot" Background="Transparent" SnapsToDevicePixels="True">

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="Auto"/>

                            <ColumnDefinition Width="*"/>

                        </Grid.ColumnDefinitions>

                        <Border x:Name="checkBoxBorder"

                                Width="18" Height="18"

                                Margin="4,0"

                                VerticalAlignment="Center"

                                HorizontalAlignment="Center"

                                Background="{StaticResource SurfaceBrush}"

                                BorderBrush="{StaticResource BorderBrush}"

                                BorderThickness="1.5"

                                CornerRadius="4">

                            <Path x:Name="optionMark"

                                  Data="M 1 4.5 L 3.5 7 L 8 1.5"

                                  Stroke="{StaticResource PrimaryBrush}"

                                  StrokeThickness="2"

                                  StrokeStartLineCap="Round"

                                  StrokeEndLineCap="Round"

                                  HorizontalAlignment="Center"

                                  VerticalAlignment="Center"

                                  Visibility="Collapsed"/>

                        </Border>

                        <ContentPresenter x:Name="contentPresenter"

                                          Grid.Column="1"

                                          ContentTemplate="{TemplateBinding ContentTemplate}"

                                          Content="{TemplateBinding Content}"

                                          ContentStringFormat="{TemplateBinding ContentStringFormat}"

                                          Margin="{TemplateBinding Padding}"

                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"

                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>

                    </Grid>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">

                            <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="{StaticResource BrushInputHover}"/>

                        </Trigger>

                        <Trigger Property="IsChecked" Value="True">

                            <Setter TargetName="optionMark" Property="Visibility" Value="Visible"/>

                            <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>

                        </Trigger>

                        <Trigger Property="IsFocused" Value="True">

                            <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="{StaticResource BrushAccent}"/>

                            <Setter TargetName="checkBoxBorder" Property="Background" Value="{StaticResource BrushAccentMuted}"/>

                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">

                            <Setter TargetName="checkBoxBorder" Property="Background" Value="{StaticResource BrushDisabledBackground}"/>

                            <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="{StaticResource BrushDisabledBorder}"/>

                            <Setter Property="Foreground" Value="{StaticResource BrushDisabledText}"/>

                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>

            </Setter.Value>

        </Setter>

    </Style>



    <!-- Modern RadioButton -->

    <Style x:Key="ModernRadioButton" TargetType="RadioButton">

        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>

        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>

        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>

        <Setter Property="VerticalContentAlignment" Value="Center"/>

        <Setter Property="HorizontalContentAlignment" Value="Left"/>

        <Setter Property="Padding" Value="8,0,8,0"/>

        <Setter Property="Cursor" Value="Hand"/>

        <Setter Property="Template">

            <Setter.Value>

                <ControlTemplate TargetType="RadioButton">

                    <Grid x:Name="templateRoot" Background="Transparent" SnapsToDevicePixels="True">

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="Auto"/>

                            <ColumnDefinition Width="*"/>

                        </Grid.ColumnDefinitions>

                        <Border x:Name="radioBorder"

                                Width="18" Height="18"

                                Margin="4,0"

                                VerticalAlignment="Center"

                                HorizontalAlignment="Center"

                                Background="{StaticResource SurfaceBrush}"

                                BorderBrush="{StaticResource BorderBrush}"

                                BorderThickness="1.5"

                                CornerRadius="9">

                            <Ellipse x:Name="optionMark"

                                     Width="8" Height="8"

                                     Fill="{StaticResource PrimaryBrush}"

                                     HorizontalAlignment="Center"

                                     VerticalAlignment="Center"

                                     Visibility="Collapsed"/>

                        </Border>

                        <ContentPresenter x:Name="contentPresenter"

                                          Grid.Column="1"

                                          ContentTemplate="{TemplateBinding ContentTemplate}"

                                          Content="{TemplateBinding Content}"

                                          ContentStringFormat="{TemplateBinding ContentStringFormat}"

                                          Margin="{TemplateBinding Padding}"

                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"

                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>

                    </Grid>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">

                            <Setter TargetName="radioBorder" Property="BorderBrush" Value="{StaticResource BrushInputHover}"/>

                        </Trigger>

                        <Trigger Property="IsChecked" Value="True">

                            <Setter TargetName="optionMark" Property="Visibility" Value="Visible"/>

                            <Setter TargetName="radioBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>

                        </Trigger>

                        <Trigger Property="IsFocused" Value="True">

                            <Setter TargetName="radioBorder" Property="BorderBrush" Value="{StaticResource BrushAccent}"/>

                            <Setter TargetName="radioBorder" Property="Background" Value="{StaticResource BrushAccentMuted}"/>

                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">

                            <Setter TargetName="radioBorder" Property="Background" Value="{StaticResource BrushDisabledBackground}"/>

                            <Setter TargetName="radioBorder" Property="BorderBrush" Value="{StaticResource BrushDisabledBorder}"/>

                            <Setter Property="Foreground" Value="{StaticResource BrushDisabledText}"/>

                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>

            </Setter.Value>

        </Setter>

    </Style>



    <!-- Menu Radio Button -->

    <Style x:Key="MenuRadioButton" TargetType="RadioButton">

        <Setter Property="Background" Value="Transparent"/>

        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>

        <Setter Property="Padding" Value="{StaticResource PaddingControlDense}"/>

        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>

        <Setter Property="Cursor" Value="Hand"/>

        <Setter Property="Template">

            <Setter.Value>

                <ControlTemplate TargetType="RadioButton">

                    <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="Transparent" BorderThickness="0" CornerRadius="{StaticResource CornerRadiusControlSmall}" Padding="{TemplateBinding Padding}" Margin="0,2">

                        <ContentPresenter HorizontalAlignment="Right" VerticalAlignment="Center"/>

                    </Border>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">

                            <Setter TargetName="border" Property="Background" Value="{StaticResource BrushAccentMuted}"/>

                            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>

                        </Trigger>

                        <Trigger Property="IsChecked" Value="True">

                            <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryBrush}"/>

                            <Setter Property="Foreground" Value="White"/>

                        </Trigger>

                        <Trigger Property="IsFocused" Value="True">

                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BrushAccent}"/>

                            <Setter TargetName="border" Property="BorderThickness" Value="1"/>

                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">

                            <Setter Property="Foreground" Value="{StaticResource BrushDisabledText}"/>

                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>

            </Setter.Value>

        </Setter>

    </Style>



    <!-- ScrollBar Styles -->

    <Style x:Key="ScrollBarThumbVertical" TargetType="Thumb">

        <Setter Property="OverridesDefaultStyle" Value="True"/>

        <Setter Property="IsTabStop" Value="False"/>

        <Setter Property="Template">

            <Setter.Value>

                <ControlTemplate TargetType="Thumb">

                    <Border x:Name="rectangle"

                            Background="{StaticResource BrushTextMuted}"

                            CornerRadius="4"

                            Height="Auto"

                            Width="8"

                            HorizontalAlignment="Center"

                            VerticalAlignment="Stretch"

                            Opacity="0.6"/>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">

                            <Setter TargetName="rectangle" Property="Background" Value="{StaticResource PrimaryLightBrush}"/>

                            <Setter TargetName="rectangle" Property="Opacity" Value="0.9"/>

                        </Trigger>

                        <Trigger Property="IsDragging" Value="True">

                            <Setter TargetName="rectangle" Property="Background" Value="{StaticResource PrimaryBrush}"/>

                            <Setter TargetName="rectangle" Property="Opacity" Value="1"/>

                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>

            </Setter.Value>

        </Setter>

    </Style>



    <Style x:Key="ScrollBarThumbHorizontal" TargetType="Thumb">

        <Setter Property="OverridesDefaultStyle" Value="True"/>

        <Setter Property="IsTabStop" Value="False"/>

        <Setter Property="Template">

            <Setter.Value>

                <ControlTemplate TargetType="Thumb">

                    <Border x:Name="rectangle"

                            Background="{StaticResource BrushTextMuted}"

                            CornerRadius="4"

                            Height="8"

                            Width="Auto"

                            HorizontalAlignment="Stretch"

                            VerticalAlignment="Center"

                            Opacity="0.6"/>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">

                            <Setter TargetName="rectangle" Property="Background" Value="{StaticResource PrimaryLightBrush}"/>

                            <Setter TargetName="rectangle" Property="Opacity" Value="0.9"/>

                        </Trigger>

                        <Trigger Property="IsDragging" Value="True">

                            <Setter TargetName="rectangle" Property="Background" Value="{StaticResource PrimaryBrush}"/>

                            <Setter TargetName="rectangle" Property="Opacity" Value="1"/>

                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>

            </Setter.Value>

        </Setter>

    </Style>

    <!-- ScrollBar Templates -->
    <ControlTemplate x:Key="VerticalScrollBarTemplate" TargetType="ScrollBar">
        <Grid x:Name="Bg" SnapsToDevicePixels="True">
            <Track x:Name="PART_Track" IsDirectionReversed="True" IsEnabled="{TemplateBinding IsEnabled}">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Focusable="False" Opacity="0" Background="Transparent" BorderThickness="0"/>
                </Track.DecreaseRepeatButton>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Focusable="False" Opacity="0" Background="Transparent" BorderThickness="0"/>
                </Track.IncreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource ScrollBarThumbVertical}"/>
                </Track.Thumb>
            </Track>
        </Grid>
    </ControlTemplate>

    <ControlTemplate x:Key="HorizontalScrollBarTemplate" TargetType="ScrollBar">
        <Grid x:Name="Bg" SnapsToDevicePixels="True">
            <Track x:Name="PART_Track" IsDirectionReversed="False" IsEnabled="{TemplateBinding IsEnabled}">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="{x:Static ScrollBar.PageLeftCommand}" Focusable="False" Opacity="0" Background="Transparent" BorderThickness="0"/>
                </Track.DecreaseRepeatButton>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="{x:Static ScrollBar.PageRightCommand}" Focusable="False" Opacity="0" Background="Transparent" BorderThickness="0"/>
                </Track.IncreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource ScrollBarThumbHorizontal}"/>
                </Track.Thumb>
            </Track>
        </Grid>
    </ControlTemplate>

    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="10"/>
        <Setter Property="Height" Value="Auto"/>
        <Setter Property="Template" Value="{StaticResource VerticalScrollBarTemplate}"/>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto"/>
                <Setter Property="Height" Value="10"/>
                <Setter Property="Template" Value="{StaticResource HorizontalScrollBarTemplate}"/>
            </Trigger>
        </Style.Triggers>
    </Style>



    <!-- Modern ScrollViewer -->

    <Style x:Key="ModernScrollViewer" TargetType="ScrollViewer">

        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>

        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>

    </Style>



    <!-- DataGrid Text Column Element Style -->

    <Style x:Key="DataGridTextColumnElementStyle" TargetType="TextBlock">

        <Setter Property="Padding" Value="0"/>

        <Setter Property="VerticalAlignment" Value="Center"/>

        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>

        <Setter Property="TextWrapping" Value="NoWrap"/>

        <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Text}"/>

    </Style>



    <!-- تطبيق افتراضي على كل حقول الإدخال -->

    <Style TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}"/>

    <Style TargetType="PasswordBox" BasedOn="{StaticResource ModernPasswordBox}"/>

    <Style TargetType="ComboBox" BasedOn="{StaticResource ModernComboBox}"/>

    <Style TargetType="DatePicker" BasedOn="{StaticResource ModernDatePicker}"/>

    <Style TargetType="CheckBox" BasedOn="{StaticResource ModernCheckBox}"/>

    <Style TargetType="RadioButton" BasedOn="{StaticResource ModernRadioButton}"/>



    <Style TargetType="ToolTip">

        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>

        <Setter Property="Background" Value="{StaticResource BrushSidebarBackground}"/>

        <Setter Property="Foreground" Value="{StaticResource BrushTextLight}"/>

        <Setter Property="BorderBrush" Value="{StaticResource BrushBorderDefault}"/>

        <Setter Property="Padding" Value="{StaticResource PaddingControlSmall}"/>

        <Setter Property="Template">

            <Setter.Value>

                <ControlTemplate TargetType="ToolTip">

                    <Border x:Name="border"

                            Background="{TemplateBinding Background}"

                            BorderBrush="{TemplateBinding BorderBrush}"

                            BorderThickness="1"

                            CornerRadius="{StaticResource CornerRadiusControlSmall}"

                            Padding="{TemplateBinding Padding}"

                            Effect="{StaticResource DropdownShadow}">

                        <ContentPresenter Content="{TemplateBinding Content}"

                                          ContentTemplate="{TemplateBinding ContentTemplate}"

                                          ContentStringFormat="{TemplateBinding ContentStringFormat}"/>

                    </Border>

                </ControlTemplate>

            </Setter.Value>

        </Setter>

    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════════════════ -->
    <!-- Centralized TextBlock Styles (Form Labels, Headers, descriptions) -->
    <!-- ═══════════════════════════════════════════════════════════════════════════════ -->

    <!-- Header Label Style (used for main window/page titles) -->
    <Style x:Key="HeaderLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeHeader}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontWeightBold}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <!-- Sub-Header Label Style (used for sub-sections) -->
    <Style x:Key="SubHeaderLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeSubHeader}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontWeightSemiBold}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <!-- Body Label Style (used for subtitles and descriptive text) -->
    <Style x:Key="BodyLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontWeightRegular}"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    </Style>

    <!-- Standard Form Input Label Style -->
    <Style x:Key="LabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontWeightSemiBold}"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
    </Style>

    <!-- Alternative Form Input Label Style (without alignment/margin constraints) -->
    <Style x:Key="FormLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontWeightSemiBold}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <!-- Dashboard Stat Value Label Style -->
    <Style x:Key="StatValueLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeTitleLarge}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontWeightBold}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════════════════ -->
    <!-- Advanced Navigation & Input Styles -->
    <!-- ═══════════════════════════════════════════════════════════════════════════════ -->

    <!-- Removed Duplicate ModernCheckBox -->

    <!-- Removed Duplicate ModernRadioButton -->

    <!-- Modern ScrollBar -->
    <Style x:Key="ModernScrollBarStyle" TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Border Background="Transparent" Width="8" Margin="0,2">
                        <Track x:Name="PART_Track" IsDirectionReversed="true">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border CornerRadius="4" Background="#CBD5E1" Opacity="0.8"/>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="1"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Removed Duplicate ModernScrollViewer -->

    <!-- Modern TabControl -->
    <Style x:Key="ModernTabControl" TargetType="TabControl">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                    <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
                    <Setter Property="FontSize" Value="{StaticResource FontSizeSubHeader}"/>
                    <Setter Property="FontWeight" Value="{StaticResource FontWeightSemiBold}"/>
                    <Setter Property="Padding" Value="16,12"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="BorderThickness" Value="0,0,0,3"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Margin="0,0,16,0">
                                    <ContentPresenter x:Name="contentPresenter" ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BrushBorderDefault}"/>
                                        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource PrimaryDarkBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════════════════ -->
    <!-- Advanced UI Framework Components (Goal Expansions) -->
    <!-- ═══════════════════════════════════════════════════════════════════════════════ -->

    <!-- Micro-Animations -->
    <Storyboard x:Key="FadeInAnimation">
        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3">
            <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseOut"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

    <Storyboard x:Key="SlideUpAnimation">
        <ThicknessAnimation Storyboard.TargetProperty="Margin" From="0,20,0,0" To="0,0,0,0" Duration="0:0:0.4">
            <ThicknessAnimation.EasingFunction>
                <CubicEase EasingMode="EaseOut"/>
            </ThicknessAnimation.EasingFunction>
        </ThicknessAnimation>
        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4">
            <DoubleAnimation.EasingFunction>
                <CubicEase EasingMode="EaseOut"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

    <!-- Modern Toggle Switch (Fluent/iOS Style) -->
    <Style x:Key="ModernToggleSwitch" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="border" Width="40" Height="22" CornerRadius="11" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1.5" VerticalAlignment="Center" Margin="0,0,10,0">
                            <Ellipse x:Name="thumb" Width="14" Height="14" Fill="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Left" Margin="3,0,0,0">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="thumbTransform" X="0"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Border>
                        <ContentPresenter Grid.Column="1" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="Checked">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="thumbTransform" Storyboard.TargetProperty="X" To="18" Duration="0:0:0.2">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Unchecked">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="thumbTransform" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.2">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            <Setter TargetName="thumb" Property="Fill" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource BrushDisabledBackground}"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BrushDisabledBorder}"/>
                            <Setter TargetName="thumb" Property="Fill" Value="{StaticResource BrushDisabledText}"/>
                            <Setter Property="Foreground" Value="{StaticResource BrushDisabledText}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Modern Badge -->
    <Style x:Key="ModernBadge" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style x:Key="ModernBadgeText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Modern Tooltip -->
    <Style TargetType="ToolTip" x:Key="ModernTooltip">
        <Setter Property="Background" Value="#1E293B"/> <!-- Dark slate -->
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="HasDropShadow" Value="True"/>
        <Setter Property="Placement" Value="Top"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}" Effect="{StaticResource DropdownShadow}">
                        <ContentPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Modern ProgressBar -->
    <Style x:Key="ModernProgressBar" TargetType="ProgressBar">
        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Height" Value="8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                        <Border x:Name="PART_Track" CornerRadius="4">
                            <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" CornerRadius="4" HorizontalAlignment="Left"/>
                        </Border>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Modern Expander -->
    <Style x:Key="ModernExpander" TargetType="Expander">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Expander">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="{StaticResource CornerRadiusControlNormal}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition x:Name="ContentRow" Height="0"/>
                            </Grid.RowDefinitions>
                            <ToggleButton x:Name="HeaderSite" Grid.Row="0" Content="{TemplateBinding Header}" ContentTemplate="{TemplateBinding HeaderTemplate}" ContentTemplateSelector="{TemplateBinding HeaderTemplateSelector}" FontFamily="{TemplateBinding FontFamily}" FontSize="{TemplateBinding FontSize}" FontWeight="{StaticResource FontWeightSemiBold}" Foreground="{TemplateBinding Foreground}" Padding="{TemplateBinding Padding}" IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="arrow" Grid.Column="1" Text="&#xE70E;" FontFamily="{StaticResource IconFont}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                                    <TextBlock.RenderTransform>
                                                        <RotateTransform Angle="0"/>
                                                    </TextBlock.RenderTransform>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="arrow" Property="RenderTransform">
                                                    <Setter.Value>
                                                        <RotateTransform Angle="180"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ExpandSite" Grid.Row="1" Margin="{TemplateBinding Padding}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" Focusable="false" Visibility="Collapsed"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="ContentRow" Property="Height" Value="Auto"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Modern Slider -->
    <Style x:Key="ModernSlider" TargetType="Slider">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border x:Name="TrackBackground" Margin="0,10" Height="4" Background="{StaticResource BrushBorderDefault}" CornerRadius="2" Grid.Row="1">
                            <Border x:Name="PART_SelectionRange" HorizontalAlignment="Left" Background="{TemplateBinding Foreground}" CornerRadius="2"/>
                        </Border>
                        <Track x:Name="PART_Track" Grid.Row="1">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="{x:Static Slider.DecreaseLarge}" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Opacity="0"/>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="{x:Static Slider.IncreaseLarge}" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Opacity="0"/>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Width="16" Height="16">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Ellipse x:Name="sliderThumb" Fill="White" Stroke="{StaticResource PrimaryBrush}" StrokeThickness="2" Effect="{StaticResource DropdownShadow}"/>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="sliderThumb" Property="StrokeThickness" Value="4"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>

